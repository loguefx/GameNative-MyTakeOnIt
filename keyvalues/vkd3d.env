# GameNative VKD3D-Proton env — set before launching Wine (DX12 games)
# Source or export these in the container startup script.
# CONTAINER_DATA_DIR must be set to writable persistent app storage.

# Pipeline library cache (DX12, same idea as DXVK state cache)
export VKD3D_CONFIG=pipeline_library_app_cache,no_upload_hvv

# Shader cache path — must be persistent (not /tmp)
export VKD3D_SHADER_CACHE_PATH="${CONTAINER_DATA_DIR}/vkd3d_cache"

# Adreno has no hardware RT — disable to avoid CPU waste
export VKD3D_DISABLE_EXTENSIONS=VK_KHR_ray_tracing_pipeline,VK_KHR_ray_query

# Async compilation worker threads (4 is sweet spot on Snapdragon)
export VKD3D_WORKER_THREAD_COUNT=4

# No debug logging
export VKD3D_DEBUG=none
export VKD3D_SHADER_DEBUG=none
