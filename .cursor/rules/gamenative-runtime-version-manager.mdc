## PART 6 — VIEWMODEL

```kotlin
@HiltViewModel
class RuntimeVersionViewModel @Inject constructor(
    private val fetcher: ProtonVersionFetcher,
    private val manager: RuntimeManager,
    private val runtimeDao: RuntimeDao
) : ViewModel() {

    private val _releasesBySource = MutableStateFlow<Map<RuntimeSource, List<RuntimeRelease>>>(emptyMap())
    val releasesBySource: StateFlow<Map<RuntimeSource, List<RuntimeRelease>>> = _releasesBySource

    private val _downloadProgress = MutableStateFlow<Map<String, Float>>(emptyMap())
    val downloadProgress: StateFlow<Map<String, Float>> = _downloadProgress

    private val _isLoading = MutableStateFlow(true)
    val isLoading: StateFlow<Boolean> = _isLoading

    // appId needed for per-game ACTIVE badge
    var currentAppId: Int = -1

    fun load(appId: Int) {
        currentAppId = appId
        viewModelScope.launch {
            _isLoading.value = true

            // Step 1: Load installed versions from Room immediately (cache-first)
            val installed = withContext(Dispatchers.IO) {
                runtimeDao.getAllInstalled()
            }
            // Show installed-only list while network loads
            emitInstalledOnly(installed, appId)

            // Step 2: Fetch from GitHub in parallel with 100ms stagger
            RuntimeSource.entries.forEachIndexed { index, source ->
                launch {
                    delay(index * 100L)   // stagger to avoid GitHub rate limit
                    val releases = withContext(Dispatchers.IO) {
                        fetcher.fetchReleases(source)
                    }
                    if (releases.isNotEmpty()) {
                        // Merge with Room data: mark installed, active, recommended
                        val merged = mergeWithInstalled(releases, installed, appId)
                        _releasesBySource.update { current ->
                            current.toMutableMap().also { it[source] = merged }
                        }
                    }
                }
            }

            _isLoading.value = false
        }
    }

    fun download(release: RuntimeRelease) {
        viewModelScope.launch {
            withContext(Dispatchers.IO) {
                manager.install(release) { downloaded, total ->
                    val progress = if (total > 0) downloaded.toFloat() / total else 0f
                    _downloadProgress.update { it.toMutableMap().also { m -> m[release.version] = progress } }
                }
            }
            // Remove progress and refresh list
            _downloadProgress.update { it.toMutableMap().also { m -> m.remove(release.version) } }
            load(currentAppId)
        }
    }

    fun setActive(release: RuntimeRelease) {
        viewModelScope.launch(Dispatchers.IO) {
            manager.setActive(currentAppId, release)
            withContext(Dispatchers.Main) { load(currentAppId) }
        }
    }

    fun remove(release: RuntimeRelease) {
        viewModelScope.launch(Dispatchers.IO) {
            manager.uninstall(release)
            withContext(Dispatchers.Main) { load(currentAppId) }
        }
    }

    private fun mergeWithInstalled(
        releases: List<RuntimeRelease>,
        installed: List<RuntimeEntity>,
        appId: Int
    ): List<RuntimeRelease> {
        val installedVersions = installed.map { it.version }.toSet()
        return releases.map { release ->
            release.copy(
                isInstalled = release.version in installedVersions,
                isActive    = installed.any {
                    it.version == release.version   // simplified; full impl checks active_runtimes table
                },
                installPath = installed.find { it.version == release.version }?.installPath ?: ""
            )
        }
    }

    private fun emitInstalledOnly(installed: List<RuntimeEntity>, appId: Int) {
        val bySource = installed.groupBy { RuntimeSource.valueOf(it.source) }
        val result = bySource.mapValues { (source, entities) ->
            entities.map { entity ->
                RuntimeRelease(
                    source      = source,
                    version     = entity.version,
                    displayName = entity.version,
                    downloadUrl = "",
                    fileName    = "",
                    sizeMb      = entity.sizeMb,
                    releaseDate = "",
                    releaseNotes = "",
                    isInstalled = true,
                    isActive    = true,   // simplified; check active_runtimes in full impl
                    installPath = entity.installPath
                )
            }
        }
        _releasesBySource.value = result
    }
}
