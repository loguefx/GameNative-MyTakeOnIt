## PART 1 — FETCHING ALL VERSIONS

### How the GitHub releases API works

```
GET https://api.github.com/repos/{owner}/{repo}/releases?per_page=20
```

Returns a JSON array of release objects. Each release has:
- `tag_name`        — version string, e.g. "GE-Proton9-20"
- `published_at`    — ISO date
- `body`            — release notes (trim to 300 chars for display)
- `assets`          — array of downloadable files

Each asset has:
- `name`            — filename, e.g. "GE-Proton9-20.tar.gz"
- `browser_download_url` — direct download link (no auth needed)
- `size`            — bytes

### ProtonVersionFetcher.kt

```kotlin
object ProtonVersionFetcher {

    // Fetch up to 20 releases from a given source
    // Returns newest-first (GitHub API default order)
    suspend fun fetchReleases(source: RuntimeSource): List<RuntimeRelease> {
        return withContext(Dispatchers.IO) {
            val url = "https://api.github.com/repos/" +
                      "${source.githubOwner}/${source.githubRepo}" +
                      "/releases?per_page=20"
            try {
                val json = URL(url).readText(Charsets.UTF_8)
                parseReleases(source, json)
            } catch (e: Exception) {
                Log.w("ProtonVersionFetcher", "Failed to fetch ${source.name}: ${e.message}")
                emptyList()
            }
        }
    }

    private fun parseReleases(source: RuntimeSource, json: String): List<RuntimeRelease> {
        val array = JSONArray(json)
        val results = mutableListOf<RuntimeRelease>()

        for (i in 0 until array.length()) {
            val release   = array.getJSONObject(i)
            val tagName   = release.getString("tag_name")
            val date      = release.optString("published_at", "").take(10)
            val notes     = release.optString("body", "").take(300)
            val assets    = release.optJSONArray("assets") ?: continue

            // Find the right asset — prefer tar.gz, fallback tar.xz
            val asset = findBestAsset(source, assets) ?: continue

            results.add(
                RuntimeRelease(
                    source      = source,
                    version     = tagName,
                    displayName = buildDisplayName(source, tagName),
                    downloadUrl = asset.getString("browser_download_url"),
                    fileName    = asset.getString("name"),
                    sizeMb      = asset.getLong("size") / 1024f / 1024f,
                    releaseDate = date,
                    releaseNotes = notes,
                    isLatest    = (i == 0)   // first in list = newest
                )
            )
        }
        return results
    }

    private fun findBestAsset(source: RuntimeSource, assets: JSONArray): JSONObject? {
        // Priority: tar.gz first, then tar.xz, then zip
        val extensions = listOf(".tar.gz", ".tar.xz", ".zip")
        for (ext in extensions) {
            for (i in 0 until assets.length()) {
                val asset = assets.getJSONObject(i)
                val name  = asset.getString("name")
                // Must match source filter AND have right extension
                // Must NOT be a sha512 checksum file
                if (name.contains(source.assetFilter, ignoreCase = true) &&
                    name.endsWith(ext) &&
                    !name.endsWith(".sha512")) {
                    return asset
                }
            }
        }
        return null
    }

    private fun buildDisplayName(source: RuntimeSource, tag: String): String {
        return when (source) {
            RuntimeSource.PROTON_GE    -> tag.replace("GE-Proton", "Proton-GE ")
            RuntimeSource.KRON4EK_WINE -> tag.replace("-amd64", "").replace("-x86_64", "")
            RuntimeSource.VALVE_PROTON -> "Proton $tag"
            RuntimeSource.WINE_GE      -> tag.replace("wine-ge-custom-", "Wine-GE ")
        }
    }
}
```

