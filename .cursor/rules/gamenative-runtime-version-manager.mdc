## PART 3 — INSTALL / UNINSTALL / ACTIVATE

### RuntimeManager.kt

```kotlin
@Singleton
class RuntimeManager @Inject constructor(
    @ApplicationContext private val context: Context,
    private val runtimeDao: RuntimeDao
) {

    // ── Install path ──────────────────────────────────────────────────────
    // All runtimes live under filesDir/runtimes/{source}/{version}/
    // e.g. filesDir/runtimes/proton_ge/GE-Proton9-20/
    fun getInstallDir(release: RuntimeRelease): File {
        val sourceDir = release.source.name.lowercase()
        return File(context.filesDir, "runtimes/$sourceDir/${release.version}")
    }

    // ── Download + extract ────────────────────────────────────────────────
    suspend fun install(
        release: RuntimeRelease,
        onProgress: (downloaded: Long, total: Long) -> Unit
    ): Result<File> = withContext(Dispatchers.IO) {
        try {
            // 1. Download to cacheDir (temp storage, OS can clear if low space)
            val cacheFile = File(context.cacheDir, release.fileName)
            downloadFile(release.downloadUrl, cacheFile, onProgress)

            // 2. Extract to filesDir (permanent app storage)
            val installDir = getInstallDir(release).also { it.mkdirs() }
            extract(cacheFile, installDir)

            // 3. Clean up cache
            cacheFile.delete()

            // 4. Record in Room
            runtimeDao.insert(
                RuntimeEntity(
                    source      = release.source.name,
                    version     = release.version,
                    installPath = installDir.absolutePath,
                    installedAt = System.currentTimeMillis(),
                    sizeMb      = release.sizeMb
                )
            )

            Result.success(installDir)
        } catch (e: Exception) {
            Result.failure(e)
        }
    }

    // ── Uninstall ─────────────────────────────────────────────────────────
    suspend fun uninstall(release: RuntimeRelease) = withContext(Dispatchers.IO) {
        getInstallDir(release).deleteRecursively()
        runtimeDao.delete(release.source.name, release.version)
        // If this was active for any game, clear that assignment
        runtimeDao.clearActiveIfVersion(release.source.name, release.version)
    }

    // ── Set active for a game ─────────────────────────────────────────────
    // Per-game: appId + source → version
    // Two games can use different Proton-GE versions simultaneously
    suspend fun setActive(appId: Int, release: RuntimeRelease) {
        withContext(Dispatchers.IO) {
            runtimeDao.setActive(
                appId   = appId,
                source  = release.source.name,
                version = release.version
            )
        }
    }

    // ── Get active version for a game ────────────────────────────────────
    suspend fun getActive(appId: Int, source: RuntimeSource): RuntimeRelease? {
        return withContext(Dispatchers.IO) {
            runtimeDao.getActive(appId, source.name)?.let { entity ->
                RuntimeRelease(
                    source      = source,
                    version     = entity.version,
                    displayName = entity.version,
                    downloadUrl = "",
                    fileName    = "",
                    sizeMb      = entity.sizeMb,
                    releaseDate = "",
                    releaseNotes = "",
                    isInstalled = true,
                    isActive    = true,
                    installPath = entity.installPath
                )
            }
        }
    }

    // ── Download helper ───────────────────────────────────────────────────
    private fun downloadFile(
        url: String,
        dest: File,
        onProgress: (Long, Long) -> Unit
    ) {
        val connection = URL(url).openConnection() as HttpURLConnection
        connection.connect()
        val total = connection.contentLengthLong
        var downloaded = 0L

        connection.inputStream.use { input ->
            dest.outputStream().use { output ->
                val buffer = ByteArray(8192)
                var bytes = input.read(buffer)
                while (bytes >= 0) {
                    output.write(buffer, 0, bytes)
                    downloaded += bytes
                    onProgress(downloaded, total)
                    bytes = input.read(buffer)
                }
            }
        }
    }

    // ── Extract helper ────────────────────────────────────────────────────
    private fun extract(archive: File, destDir: File) {
        when {
            archive.name.endsWith(".tar.gz") || archive.name.endsWith(".tgz") ->
                Runtime.getRuntime()
                    .exec(arrayOf("tar", "xzf", archive.absolutePath, "-C", destDir.absolutePath))
                    .waitFor()
            archive.name.endsWith(".tar.xz") ->
                Runtime.getRuntime()
                    .exec(arrayOf("tar", "xJf", archive.absolutePath, "-C", destDir.absolutePath))
                    .waitFor()
            archive.name.endsWith(".zip") -> extractZip(archive, destDir)
        }
    }

    private fun extractZip(zip: File, dest: File) {
        java.util.zip.ZipFile(zip).use { zipFile ->
            zipFile.entries().asSequence().forEach { entry ->
                val outFile = File(dest, entry.name)
                if (entry.isDirectory) outFile.mkdirs()
                else {
                    outFile.parentFile?.mkdirs()
                    zipFile.getInputStream(entry).use { it.copyTo(outFile.outputStream()) }
                }
            }
        }
    }
}
```

