## PART 4 — ROOM ENTITIES AND DAO

Add these to the existing AppDatabase — do NOT create a new database.

```kotlin
// ── Entity: installed runtime ─────────────────────────────────────────────
@Entity(tableName = "installed_runtimes")
data class RuntimeEntity(
    @PrimaryKey(autoGenerate = true) val id: Int = 0,
    val source: String,         // RuntimeSource.name
    val version: String,        // raw tag
    val installPath: String,
    val installedAt: Long,
    val sizeMb: Float
)

// ── Entity: per-game active version ──────────────────────────────────────
// One row per (appId, source) — which version is active for that game
@Entity(
    tableName = "active_runtimes",
    primaryKeys = ["appId", "source"]
)
data class ActiveRuntimeEntity(
    val appId: Int,
    val source: String,
    val version: String
)

// ── DAO ───────────────────────────────────────────────────────────────────
@Dao
interface RuntimeDao {

    @Insert(onConflict = OnConflictStrategy.REPLACE)
    suspend fun insert(entity: RuntimeEntity)

    @Query("DELETE FROM installed_runtimes WHERE source = :source AND version = :version")
    suspend fun delete(source: String, version: String)

    @Query("SELECT * FROM installed_runtimes WHERE source = :source ORDER BY installedAt DESC")
    suspend fun getInstalled(source: String): List<RuntimeEntity>

    @Query("SELECT * FROM installed_runtimes ORDER BY installedAt DESC")
    suspend fun getAllInstalled(): List<RuntimeEntity>

    // Per-game active version
    @Insert(onConflict = OnConflictStrategy.REPLACE)
    suspend fun setActive(entity: ActiveRuntimeEntity)

    suspend fun setActive(appId: Int, source: String, version: String) {
        setActive(ActiveRuntimeEntity(appId, source, version))
    }

    @Query("SELECT * FROM installed_runtimes WHERE source = :source AND version = " +
           "(SELECT version FROM active_runtimes WHERE appId = :appId AND source = :source LIMIT 1)")
    suspend fun getActive(appId: Int, source: String): RuntimeEntity?

    @Query("DELETE FROM active_runtimes WHERE source = :source AND version = :version")
    suspend fun clearActiveIfVersion(source: String, version: String)
}
```

