### RuntimeVersionSection composable

```kotlin
@Composable
fun RuntimeVersionSection(
    source: RuntimeSource,
    releases: List<RuntimeRelease>,          // from GitHub + merged with Room data
    downloadProgress: Map<String, Float>,    // version → 0.0-1.0
    appId: Int,
    onDownload: (RuntimeRelease) -> Unit,
    onSetActive: (RuntimeRelease) -> Unit,
    onRemove: (RuntimeRelease) -> Unit
) {
    var expanded by remember { mutableStateOf(false) }
    val visibleReleases = if (expanded) releases else releases.take(5)

    Column(verticalArrangement = Arrangement.spacedBy(8.dp)) {

        // Section header
        Column(
            modifier = Modifier.fillMaxWidth(),
            verticalArrangement = Arrangement.spacedBy(3.dp)
        ) {
            Row(
                modifier = Modifier.fillMaxWidth(),
                horizontalArrangement = Arrangement.SpaceBetween,
                verticalAlignment = Alignment.CenterVertically
            ) {
                Text(
                    text = source.displayName.uppercase(),
                    style = PluviaTypography.labelSmall.copy(
                        letterSpacing = 0.10.sp,
                        fontWeight = FontWeight.Bold
                    ),
                    color = gnTextTertiary
                )
                TextButton(
                    onClick = { /* open GitHub URL */ },
                    contentPadding = PaddingValues(horizontal = 8.dp, vertical = 4.dp)
                ) {
                    Icon(Icons.Default.OpenInBrowser, null,
                        modifier = Modifier.size(12.dp), tint = gnTextTertiary)
                    Spacer(Modifier.width(4.dp))
                    Text("GitHub", style = PluviaTypography.labelSmall, color = gnTextTertiary)
                }
            }
            Text(
                text = source.description,
                style = PluviaTypography.bodySmall,
                color = gnTextTertiary
            )
        }

        // Version rows card
        Card(
            colors = CardDefaults.cardColors(containerColor = gnBgSurface),
            border = BorderStroke(1.dp, gnBorderCard),
            shape = RoundedCornerShape(12.dp)
        ) {
            visibleReleases.forEachIndexed { index, release ->
                RuntimeVersionRow(
                    release  = release,
                    progress = downloadProgress[release.version],
                    onDownload  = { onDownload(release) },
                    onSetActive = { onSetActive(release) },
                    onRemove    = { onRemove(release) }
                )
                if (index < visibleReleases.lastIndex) {
                    Divider(
                        color = gnDivider,
                        modifier = Modifier.padding(horizontal = 16.dp)
                    )
                }
            }

            // Show older / collapse button
            if (releases.size > 5) {
                Divider(color = gnDivider)
                TextButton(
                    onClick = { expanded = !expanded },
                    modifier = Modifier
                        .fillMaxWidth()
                        .height(44.dp),
                    colors = ButtonDefaults.textButtonColors(contentColor = gnTextSecondary)
                ) {
                    Text(
                        text = if (expanded)
                            "Show fewer versions ▲"
                        else
                            "Show ${releases.size - 5} older versions ▼",
                        style = PluviaTypography.labelMedium
                    )
                }
            }
        }
    }
}

@Composable
fun RuntimeVersionRow(
    release: RuntimeRelease,
    progress: Float?,
    onDownload: () -> Unit,
    onSetActive: () -> Unit,
    onRemove: () -> Unit
) {
    var showNotes by remember { mutableStateOf(false) }

    Column {
        Row(
            modifier = Modifier
                .fillMaxWidth()
                .clickable(enabled = release.releaseNotes.isNotBlank()) {
                    showNotes = !showNotes
                }
                .padding(horizontal = 16.dp, vertical = 12.dp),
            horizontalArrangement = Arrangement.SpaceBetween,
            verticalAlignment = Alignment.CenterVertically
        ) {
            // Left: name, badges, date + size
            Column(
                modifier = Modifier.weight(1f),
                verticalArrangement = Arrangement.spacedBy(5.dp)
            ) {
                // Name + badges row
                Row(
                    horizontalArrangement = Arrangement.spacedBy(6.dp),
                    verticalAlignment = Alignment.CenterVertically,
                    modifier = Modifier.fillMaxWidth()
                ) {
                    Text(
                        text = release.displayName,
                        style = PluviaTypography.bodyMedium.copy(fontWeight = FontWeight.SemiBold),
                        color = if (release.isInstalled || release.isLatest)
                            gnTextPrimary else gnTextSecondary
                    )
                    if (release.isLatest) {
                        VersionBadge("LATEST", gnNeonTeal)
                    }
                    if (release.isRecommended) {
                        VersionBadge("RECOMMENDED", gnAccentGlow)
                    }
                    if (release.isActive) {
                        VersionBadge("ACTIVE", gnAccentPrimary)
                    }
                }

                // Date + size + installed status
                Row(
                    horizontalArrangement = Arrangement.spacedBy(12.dp),
                    verticalAlignment = Alignment.CenterVertically
                ) {
                    if (release.releaseDate.isNotBlank()) {
                        Text(
                            text = release.releaseDate,
                            style = PluviaTypography.labelSmall,
                            color = gnTextTertiary
                        )
                    }
                    Text(
                        text = if (release.isInstalled)
                            "Installed · %.0f MB".format(release.sizeMb)
                        else
                            "%.0f MB".format(release.sizeMb),
                        style = PluviaTypography.labelSmall,
                        color = if (release.isInstalled) gnNeonTeal else gnTextTertiary
                    )
                }
            }

            Spacer(Modifier.width(12.dp))

            // Right: action area
            when {
                // Currently downloading
                progress != null -> {
                    Box(
                        modifier = Modifier.size(44.dp),
                        contentAlignment = Alignment.Center
                    ) {
                        CircularProgressIndicator(
                            progress = { progress },
                            modifier = Modifier.size(36.dp),
                            color = gnAccentPrimary,
                            strokeWidth = 3.dp,
                            trackColor = gnBgOverlay
                        )
                        Text(
                            text = "${(progress * 100).toInt()}%",
                            style = PluviaTypography.labelSmall.copy(fontSize = 8.sp),
                            color = gnTextPrimary
                        )
                    }
                }

                // Not installed — show Download button
                !release.isInstalled -> {
                    OutlinedButton(
                        onClick = onDownload,
                        border = BorderStroke(1.dp, gnAccentPrimary.copy(alpha = 0.6f)),
                        shape = RoundedCornerShape(8.dp),
                        colors = ButtonDefaults.outlinedButtonColors(contentColor = gnAccentPrimary),
                        contentPadding = PaddingValues(horizontal = 14.dp, vertical = 0.dp),
                        modifier = Modifier.height(36.dp)
                    ) {
                        Icon(Icons.Default.Download, null, modifier = Modifier.size(14.dp))
                        Spacer(Modifier.width(5.dp))
                        Text("Download", style = PluviaTypography.labelMedium)
                    }
                }

                // Installed and active — checkmark only
                release.isActive -> {
                    Row(
                        horizontalArrangement = Arrangement.spacedBy(8.dp),
                        verticalAlignment = Alignment.CenterVertically
                    ) {
                        Icon(
                            Icons.Default.CheckCircle,
                            contentDescription = null,
                            tint = gnNeonTeal,
                            modifier = Modifier.size(22.dp)
                        )
                    }
                }

                // Installed but not active — Use + Remove
                else -> {
                    Row(
                        horizontalArrangement = Arrangement.spacedBy(6.dp),
                        verticalAlignment = Alignment.CenterVertically
                    ) {
                        TextButton(
                            onClick = onRemove,
                            colors = ButtonDefaults.textButtonColors(contentColor = gnStatusError),
                            contentPadding = PaddingValues(horizontal = 8.dp)
                        ) {
                            Text("Remove", style = PluviaTypography.labelMedium)
                        }
                        OutlinedButton(
                            onClick = onSetActive,
                            border = BorderStroke(1.dp, gnBorderCard),
                            shape = RoundedCornerShape(8.dp),
                            colors = ButtonDefaults.outlinedButtonColors(contentColor = gnTextSecondary),
                            contentPadding = PaddingValues(horizontal = 14.dp, vertical = 0.dp),
                            modifier = Modifier.height(36.dp)
                        ) {
                            Text("Use", style = PluviaTypography.labelMedium)
                        }
                    }
                }
            }
        }

        // Download progress bar (full width under row)
        if (progress != null) {
            LinearProgressIndicator(
                progress = { progress },
                modifier = Modifier.fillMaxWidth().height(2.dp),
                color = gnAccentPrimary,
                trackColor = Color.Transparent
            )
        }

        // Expandable release notes
        AnimatedVisibility(visible = showNotes) {
            Text(
                text = release.releaseNotes,
                style = PluviaTypography.bodySmall,
                color = gnTextSecondary,
                modifier = Modifier
                    .fillMaxWidth()
                    .background(gnBgElevated)
                    .padding(horizontal = 16.dp, vertical = 10.dp)
            )
        }
    }
}

@Composable
fun VersionBadge(label: String, color: Color) {
    Box(
        modifier = Modifier
            .background(color.copy(alpha = 0.12f), RoundedCornerShape(4.dp))
            .border(0.5.dp, color.copy(alpha = 0.35f), RoundedCornerShape(4.dp))
