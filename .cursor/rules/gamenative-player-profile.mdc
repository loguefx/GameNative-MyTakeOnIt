### Nav graph additions

```kotlin
// Add to your existing NavHost:
composable(
    route = "playerProfile/{steamId}",
    arguments = listOf(navArgument("steamId") { type = NavType.StringType })
) { backStackEntry ->
    val steamId = backStackEntry.arguments?.getString("steamId") ?: return@composable
    PlayerProfileScreen(
        steamId = steamId,
        onNavigateToChat = { navController.navigate("chat/$steamId") },
        onNavigateBack = { navController.popBackStack() },
        onNavigateToCompare = { navController.navigate("compareAchievements/$steamId") }
    )
}
