```kotlin
// Image loading — Kotlin-first, faster than Glide, supports Coil transforms
implementation("io.coil-kt:coil:2.6.0")

// Shimmer skeleton loading placeholder
implementation("com.facebook.shimmer:shimmer:0.5.0")

// Confirm these are present and at these minimum versions
