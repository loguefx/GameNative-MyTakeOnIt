## PART 3 — INTELLIGENT RECOMMENDATION ENGINE

### How it works

When the settings screen opens, the engine:
1. Reads hardware profile (cached from first launch)
2. Reads ProtonDB tier for this game
3. Checks KnownGameFixes for any hardcoded overrides
4. Runs CompatibilityChecker for warnings/blockers
5. Generates a recommended config
6. Shows a "Recommended Settings" banner with one-tap apply

### RecommendationBanner composable

```kotlin
@Composable
fun RecommendationBanner(
    recommendation: GameConfig,
    onApply: () -> Unit,
    onDismiss: () -> Unit
) {
    var expanded by remember { mutableStateOf(false) }

    Card(
        modifier = Modifier.fillMaxWidth(),
        colors = CardDefaults.cardColors(containerColor = gnAccentPrimary.copy(alpha = 0.08f)),
        border = BorderStroke(1.dp, gnAccentPrimary.copy(alpha = 0.3f)),
        shape = RoundedCornerShape(12.dp)
    ) {
        Column(modifier = Modifier.padding(14.dp), verticalArrangement = Arrangement.spacedBy(10.dp)) {

            // Header
            Row(
                horizontalArrangement = Arrangement.SpaceBetween,
                verticalAlignment = Alignment.CenterVertically,
                modifier = Modifier.fillMaxWidth()
            ) {
                Row(horizontalArrangement = Arrangement.spacedBy(8.dp), verticalAlignment = Alignment.CenterVertically) {
                    Icon(Icons.Default.AutoFixHigh, null, tint = gnAccentGlow, modifier = Modifier.size(18.dp))
                    Text(
                        "Recommended for your device",
                        style = PluviaTypography.titleSmall.copy(fontWeight = FontWeight.SemiBold),
                        color = gnAccentGlow
                    )
                }
                IconButton(onClick = onDismiss, modifier = Modifier.size(24.dp)) {
                    Icon(Icons.Default.Close, null, tint = gnTextTertiary, modifier = Modifier.size(16.dp))
                }
            }

            // Summary pills
            Text(recommendation.notes, style = PluviaTypography.bodySmall, color = gnTextSecondary)

            // Key settings preview
            if (expanded) {
                Column(verticalArrangement = Arrangement.spacedBy(4.dp)) {
                    RecommendationPill("Runtime", recommendation.protonVersion.displayName)
                    RecommendationPill("DirectX", recommendation.dxVersion.name)
                    RecommendationPill("Resolution", "${(recommendation.resolutionScale * 100).toInt()}%")
                    RecommendationPill("FPS Cap", if (recommendation.fpsLimit == 0) "Uncapped" else "${recommendation.fpsLimit} FPS")
                    RecommendationPill("VRAM", "${recommendation.dxvkDeviceLocalMemoryMiB} MB")
                }
            }

            // Actions
            Row(horizontalArrangement = Arrangement.spacedBy(8.dp)) {
                OutlinedButton(
                    onClick = { expanded = !expanded },
                    border = BorderStroke(1.dp, gnBorderCard),
                    shape = RoundedCornerShape(8.dp),
                    colors = ButtonDefaults.outlinedButtonColors(contentColor = gnTextSecondary),
                    modifier = Modifier.height(36.dp)
                ) {
                    Text(if (expanded) "Hide details" else "Show details", style = PluviaTypography.labelMedium)
                }
                Button(
                    onClick = onApply,
                    colors = ButtonDefaults.buttonColors(containerColor = gnAccentPrimary),
                    shape = RoundedCornerShape(8.dp),
                    modifier = Modifier.height(36.dp)
                ) {
                    Icon(Icons.Default.AutoFixHigh, null, modifier = Modifier.size(14.dp))
                    Spacer(Modifier.width(6.dp))
                    Text("Apply Recommended", style = PluviaTypography.labelLarge.copy(fontWeight = FontWeight.SemiBold))
                }
            }
        }
    }
}

