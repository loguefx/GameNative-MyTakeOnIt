```kotlin
@Composable
fun ComponentItem(
    name: String,
    size: String,
    isInstalled: Boolean,
    isActive: Boolean,
    onDownload: () -> Unit,
    onRemove: () -> Unit
) {
    Row(
        modifier = Modifier
            .fillMaxWidth()
            .padding(horizontal = 16.dp, vertical = 10.dp),
        horizontalArrangement = Arrangement.SpaceBetween,
        verticalAlignment = Alignment.CenterVertically
    ) {
        Column(modifier = Modifier.weight(1f)) {
            Row(horizontalArrangement = Arrangement.spacedBy(8.dp), verticalAlignment = Alignment.CenterVertically) {
                Text(name, style = PluviaTypography.bodyMedium.copy(fontWeight = FontWeight.Medium), color = gnTextPrimary)
                if (isActive) {
                    Box(
                        modifier = Modifier
                            .background(gnAccentPrimary.copy(alpha = 0.15f), RoundedCornerShape(4.dp))
                            .padding(horizontal = 6.dp, vertical = 2.dp)
                    ) {
                        Text("ACTIVE", style = PluviaTypography.labelSmall.copy(fontSize = 9.sp), color = gnAccentGlow)
                    }
                }
            }
            Text(size, style = PluviaTypography.bodySmall, color = gnTextTertiary)
        }
        if (isInstalled) {
            Row(horizontalArrangement = Arrangement.spacedBy(8.dp)) {
                TextButton(onClick = onRemove) {
                    Text("Remove", color = gnStatusError, style = PluviaTypography.labelMedium)
                }
                Icon(Icons.Default.CheckCircle, null, tint = gnNeonTeal, modifier = Modifier.size(20.dp))
            }
        } else {
            Button(
                onClick = onDownload,
                colors = ButtonDefaults.buttonColors(containerColor = gnBgElevated, contentColor = gnAccentPrimary),
                contentPadding = PaddingValues(horizontal = 12.dp, vertical = 6.dp),
                shape = RoundedCornerShape(8.dp)
            ) {
                Icon(Icons.Default.Download, null, modifier = Modifier.size(14.dp))
                Spacer(Modifier.width(4.dp))
                Text("Download", style = PluviaTypography.labelMedium)
            }
        }
    }
}
