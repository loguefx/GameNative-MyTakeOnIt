## PART 6 — SETTINGS CONTENT AREA

```kotlin
@Composable
fun SettingsCategoryContent(
    category: SettingsCategory,
    config: GameConfig,
    hardware: HardwareProfile?,
    compatResult: CompatibilityChecker.CompatibilityResult?,
    recommendation: GameConfig?,
    showRecommendation: Boolean,
    onUpdate: (GameConfig) -> Unit,
    onApplyRecommendation: () -> Unit,
    onDismissRecommendation: () -> Unit
) {
    LazyColumn(
        modifier = Modifier.fillMaxSize(),
        contentPadding = PaddingValues(16.dp),
        verticalArrangement = Arrangement.spacedBy(10.dp)
    ) {
        // Compatibility banners always at top
        if (compatResult != null &&
            (compatResult.warnings.isNotEmpty() || compatResult.blockers.isNotEmpty())) {
            item { CompatibilityBanner(result = compatResult) }
        }

        // Recommendation banner (only on General and Compatibility tabs)
        if (showRecommendation && recommendation != null &&
            (category == SettingsCategory.GENERAL || category == SettingsCategory.COMPATIBILITY)) {
            item {
                RecommendationBanner(
                    recommendation = recommendation,
                    onApply = onApplyRecommendation,
                    onDismiss = onDismissRecommendation
                )
            }
        }

        // Category-specific content
        when (category) {
            SettingsCategory.GENERAL       -> generalItems(config, onUpdate)
            SettingsCategory.COMPATIBILITY -> compatibilityItems(config, hardware, onUpdate)
            SettingsCategory.COMPONENT     -> componentItems()
            SettingsCategory.BACKUP_RESTORE -> backupItems()
            SettingsCategory.CONTROLLER    -> controllerItems(config, onUpdate)
            SettingsCategory.INPUT_MAPPING -> inputMappingItems(config, onUpdate)
            SettingsCategory.TOUCH_CONTROLS -> touchControlItems(config, onUpdate)
        }
    }
}
