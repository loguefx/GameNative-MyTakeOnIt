## PART 1 — COMPATIBILITY WARNING SYSTEM

This is the most important part. Run this check BEFORE the settings
screen loads and BEFORE any launch attempt.

### CompatibilityChecker.kt

```kotlin
object CompatibilityChecker {

    data class CompatibilityResult(
        val canRun: Boolean,
        val warnings: List<CompatWarning>,
        val blockers: List<CompatBlocker>,   // hard blockers = cannot run
        val recommendedAction: String
    )

    data class CompatWarning(
        val icon: ImageVector,
        val title: String,
        val detail: String,
        val severity: Severity   // LOW, MEDIUM, HIGH
    )

    data class CompatBlocker(
        val icon: ImageVector,
        val title: String,
        val detail: String,
        val fixAction: String?   // label of button to fix it, null if unfixable
    )

    enum class Severity { LOW, MEDIUM, HIGH }

    fun check(
        context: Context,
        appId: Int,
        gameName: String,
        hardware: HardwareProfile,
        gameRequirements: GameRequirements?  // from SteamAPI if available
    ): CompatibilityResult {

        val warnings  = mutableListOf<CompatWarning>()
        val blockers  = mutableListOf<CompatBlocker>()

        // ── RAM check ────────────────────────────────────────────────────
        val requiredRamMb = gameRequirements?.minimumRamMb ?: 4096
        val recommendedRamMb = gameRequirements?.recommendedRamMb ?: 8192

        when {
            hardware.availableRamMb < requiredRamMb -> blockers.add(
                CompatBlocker(
                    icon = Icons.Default.Memory,
                    title = "Insufficient RAM",
                    detail = "This game requires ${requiredRamMb / 1024}GB RAM minimum. " +
                             "Your device has ${hardware.totalRamMb / 1024}GB total " +
                             "(${hardware.availableRamMb / 1024}GB currently available). " +
                             "Close background apps and try again.",
                    fixAction = "Free Up Memory"
                )
            )
            hardware.availableRamMb < recommendedRamMb -> warnings.add(
                CompatWarning(
                    icon = Icons.Default.Memory,
                    title = "Low Available RAM",
                    detail = "Recommended: ${recommendedRamMb / 1024}GB. " +
                             "You have ${hardware.availableRamMb / 1024}GB available. " +
                             "Performance may be reduced. Close other apps for best results.",
                    severity = Severity.MEDIUM
                )
            )
        }

        // ── Storage check ────────────────────────────────────────────────
        val requiredStorageMb = gameRequirements?.storageMb ?: 0
        val freeStorageMb = getFreeStorageMb(context)
        if (requiredStorageMb > 0 && freeStorageMb < requiredStorageMb + 2048) {
            blockers.add(
                CompatBlocker(
                    icon = Icons.Default.Storage,
                    title = "Not Enough Storage",
                    detail = "This game needs ${formatSize(requiredStorageMb)}. " +
                             "You have ${formatSize(freeStorageMb)} free. " +
                             "Free up ${formatSize(requiredStorageMb - freeStorageMb + 2048)} to continue.",
                    fixAction = "Open Storage Settings"
                )
            )
        }

        // ── Vulkan check ─────────────────────────────────────────────────
        if (!hardware.supportsVulkan13) {
            if (hardware.gpuVulkanVersion.startsWith("1.1") ||
                hardware.gpuVulkanVersion.startsWith("1.0")) {
                blockers.add(
                    CompatBlocker(
                        icon = Icons.Default.BrokenImage,
                        title = "Vulkan Version Too Old",
                        detail = "Your GPU supports Vulkan ${hardware.gpuVulkanVersion}. " +
                                 "Most Steam games require Vulkan 1.2 or higher. " +
                                 "DXVK and VKD3D will not function correctly.",
                        fixAction = null   // unfixable without new hardware
                    )
                )
            } else {
                warnings.add(
                    CompatWarning(
                        icon = Icons.Default.Warning,
                        title = "Vulkan 1.3 Not Supported",
                        detail = "Your GPU supports Vulkan ${hardware.gpuVulkanVersion}. " +
                                 "Some DX12 features may not work. " +
                                 "DX11 mode recommended for this device.",
                        severity = Severity.MEDIUM
                    )
                )
            }
        }

        // ── GPU family check ──────────────────────────────────────────────
        if (hardware.gpuVendor == GpuVendor.MALI) {
            warnings.add(
                CompatWarning(
                    icon = Icons.Default.Info,
                    title = "Mali GPU Detected",
                    detail = "Community Turnip GPU driver is only available for Adreno GPUs. " +
                             "Your Mali GPU will use the stock driver, which may have " +
                             "lower Vulkan performance. DX11 mode recommended.",
                    severity = Severity.HIGH
                )
            )
        }

        // ── Thermal check ─────────────────────────────────────────────────
        if (hardware.thermalHeadroom < 0.2f) {
            warnings.add(
                CompatWarning(
                    icon = Icons.Default.Thermostat,
                    title = "Device Running Hot",
                    detail = "Your device is near its thermal limit. " +
                             "Performance will be throttled to prevent overheating. " +
                             "Let your device cool down for best performance.",
                    severity = Severity.HIGH
                )
            )
        }

        // ── ProtonDB borked check ─────────────────────────────────────────
        if (KnownGameFixes.isBorked(appId)) {
            warnings.add(
                CompatWarning(
                    icon = Icons.Default.ErrorOutline,
                    title = "Known Compatibility Issues",
                    detail = "${KnownGameFixes.getBorkedReason(appId) ?: "This game has reported issues on Linux/Proton."} " +
                             "Try the Compatibility preset and Wine-GE runtime.",
                    severity = Severity.HIGH
                )
            )
        }

        // ── 32-bit game on 64-bit only container ──────────────────────────
        if (KnownGameFixes.is32BitOnly(appId) && !container32BitSupported()) {
            warnings.add(
                CompatWarning(
                    icon = Icons.Default.Warning,
                    title = "32-bit Game",
                    detail = "This game is 32-bit only. Ensure WoW64 mode is enabled " +
                             "in Compatibility settings, or it will fail to launch.",
                    severity = Severity.HIGH
                )
            )
        }

        val canRun = blockers.isEmpty()

        return CompatibilityResult(
            canRun = canRun,
            warnings = warnings,
            blockers = blockers,
            recommendedAction = when {
                !canRun                  -> "Cannot launch — fix blockers first"
                warnings.any { it.severity == Severity.HIGH } ->
                    "Can launch with reduced performance — review warnings"
                warnings.isNotEmpty()    -> "May run with minor issues"
                else                     -> "Should run well on this device"
            }
        )
    }
}
```

### Compatibility banner shown at top of settings screen

```kotlin
@Composable
fun CompatibilityBanner(result: CompatibilityResult) {
    if (result.blockers.isEmpty() && result.warnings.isEmpty()) {
        // Green — all good
        Card(
            modifier = Modifier.fillMaxWidth(),
            colors = CardDefaults.cardColors(containerColor = gnNeonTeal.copy(alpha = 0.1f)),
            border = BorderStroke(1.dp, gnNeonTeal.copy(alpha = 0.3f)),
            shape = RoundedCornerShape(10.dp)
        ) {
            Row(modifier = Modifier.padding(12.dp), horizontalArrangement = Arrangement.spacedBy(10.dp)) {
                Icon(Icons.Default.CheckCircle, null, tint = gnNeonTeal, modifier = Modifier.size(18.dp))
                Text(
                    "This game should run well on your device.",
                    style = PluviaTypography.bodySmall,
                    color = gnNeonTeal
                )
            }
        }
        return
    }

    // Blockers — red, cannot run
    result.blockers.forEach { blocker ->
        Card(
            modifier = Modifier.fillMaxWidth(),
            colors = CardDefaults.cardColors(containerColor = gnStatusError.copy(alpha = 0.1f)),
            border = BorderStroke(1.dp, gnStatusError.copy(alpha = 0.4f)),
            shape = RoundedCornerShape(10.dp)
        ) {
            Column(modifier = Modifier.padding(12.dp), verticalArrangement = Arrangement.spacedBy(6.dp)) {
                Row(horizontalArrangement = Arrangement.spacedBy(8.dp), verticalAlignment = Alignment.CenterVertically) {
                    Icon(blocker.icon, null, tint = gnStatusError, modifier = Modifier.size(16.dp))
                    Text(blocker.title, style = PluviaTypography.labelLarge.copy(fontWeight = FontWeight.SemiBold), color = gnStatusError)
                }
                Text(blocker.detail, style = PluviaTypography.bodySmall, color = gnTextSecondary)
                if (blocker.fixAction != null) {
                    TextButton(onClick = { /* handle fix */ }) {
                        Text(blocker.fixAction, color = gnStatusError, style = PluviaTypography.labelLarge)
                    }
                }
            }
        }
    }

    // Warnings — orange, can run but with issues
    result.warnings.forEach { warning ->
        val color = when (warning.severity) {
            CompatibilityChecker.Severity.HIGH   -> gnNeonOrange
            CompatibilityChecker.Severity.MEDIUM -> gnNeonOrange.copy(alpha = 0.7f)
            CompatibilityChecker.Severity.LOW    -> gnTextSecondary
        }
        Card(
            modifier = Modifier.fillMaxWidth(),
            colors = CardDefaults.cardColors(containerColor = color.copy(alpha = 0.08f)),
            border = BorderStroke(1.dp, color.copy(alpha = 0.3f)),
            shape = RoundedCornerShape(10.dp)
        ) {
            Row(modifier = Modifier.padding(12.dp), horizontalArrangement = Arrangement.spacedBy(10.dp)) {
                Icon(warning.icon, null, tint = color, modifier = Modifier.size(16.dp))
                Column(verticalArrangement = Arrangement.spacedBy(3.dp)) {
                    Text(warning.title, style = PluviaTypography.labelLarge.copy(fontWeight = FontWeight.SemiBold), color = color)
                    Text(warning.detail, style = PluviaTypography.bodySmall, color = gnTextSecondary)
                }
            }
        }
    }
}
