## PART 4 — CANNOT RUN SCREEN

When CompatibilityChecker returns `canRun = false`, show this instead
of the normal settings screen:

```kotlin
@Composable
fun CannotRunScreen(
    gameName: String,
    blockers: List<CompatibilityChecker.CompatBlocker>,
    onOpenSettings: () -> Unit,   // still allow opening settings to try anyway
    onNavigateBack: () -> Unit
) {
    Column(
        modifier = Modifier
            .fillMaxSize()
            .background(gnBgDeepest)
            .padding(24.dp),
        horizontalAlignment = Alignment.CenterHorizontally,
        verticalArrangement = Arrangement.spacedBy(16.dp)
    ) {
        Spacer(Modifier.height(32.dp))

        // Icon
        Box(
            modifier = Modifier
                .size(80.dp)
                .background(gnStatusError.copy(alpha = 0.1f), CircleShape)
                .border(1.dp, gnStatusError.copy(alpha = 0.3f), CircleShape),
            contentAlignment = Alignment.Center
        ) {
            Icon(Icons.Default.VideogameAssetOff, null, tint = gnStatusError, modifier = Modifier.size(36.dp))
        }

        Text(
            "Cannot Run $gameName",
            style = PluviaTypography.headlineSmall.copy(fontWeight = FontWeight.Bold),
            color = gnTextPrimary,
            textAlign = TextAlign.Center
        )

        Text(
            "Your device doesn't meet the requirements to run this game.",
            style = PluviaTypography.bodyMedium,
            color = gnTextSecondary,
            textAlign = TextAlign.Center
        )

        // Blocker list
        blockers.forEach { blocker ->
            Card(
                modifier = Modifier.fillMaxWidth(),
                colors = CardDefaults.cardColors(containerColor = gnStatusError.copy(alpha = 0.08f)),
                border = BorderStroke(1.dp, gnStatusError.copy(alpha = 0.3f)),
                shape = RoundedCornerShape(10.dp)
            ) {
                Column(modifier = Modifier.padding(14.dp), verticalArrangement = Arrangement.spacedBy(6.dp)) {
                    Row(horizontalArrangement = Arrangement.spacedBy(8.dp), verticalAlignment = Alignment.CenterVertically) {
                        Icon(blocker.icon, null, tint = gnStatusError, modifier = Modifier.size(16.dp))
                        Text(blocker.title, style = PluviaTypography.labelLarge.copy(fontWeight = FontWeight.SemiBold), color = gnStatusError)
                    }
                    Text(blocker.detail, style = PluviaTypography.bodySmall, color = gnTextSecondary)
                    if (blocker.fixAction != null) {
                        TextButton(onClick = { /* handle */ }) {
                            Text(blocker.fixAction, color = gnAccentPrimary)
                        }
                    }
                }
            }
        }

        Spacer(Modifier.weight(1f))

        // Still allow trying (for advanced users who know what they're doing)
        OutlinedButton(
            onClick = onOpenSettings,
            border = BorderStroke(1.dp, gnBorderCard),
            modifier = Modifier.fillMaxWidth().height(48.dp),
            shape = RoundedCornerShape(10.dp),
            colors = ButtonDefaults.outlinedButtonColors(contentColor = gnTextSecondary)
        ) {
            Icon(Icons.Default.Settings, null, modifier = Modifier.size(16.dp))
            Spacer(Modifier.width(8.dp))
            Text("Open Settings Anyway", style = PluviaTypography.labelLarge)
        }

        Button(
            onClick = onNavigateBack,
            modifier = Modifier.fillMaxWidth().height(48.dp),
            colors = ButtonDefaults.buttonColors(containerColor = gnBgElevated, contentColor = gnTextPrimary),
            shape = RoundedCornerShape(10.dp)
        ) {
            Text("Go Back", style = PluviaTypography.labelLarge)
        }
    }
}
