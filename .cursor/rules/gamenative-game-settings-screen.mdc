## PART 5 — SETTINGS SCREEN FULL IMPLEMENTATION

```kotlin
@Composable
fun GameSettingsScreen(
    appId: Int,
    gameName: String,
    onLaunch: (GameConfig) -> Unit,
    onNavigateBack: () -> Unit,
    viewModel: GameSettingsViewModel = hiltViewModel()
) {
    val uiState by viewModel.uiState.collectAsState()
    val selectedCategory by viewModel.selectedCategory.collectAsState()
    val config by viewModel.config.collectAsState()
    val compatResult by viewModel.compatResult.collectAsState()
    val recommendation by viewModel.recommendation.collectAsState()
    val showRecommendation by viewModel.showRecommendation.collectAsState()

    LaunchedEffect(appId) { viewModel.load(appId) }

    // Show cannot-run screen if hard blockers exist
    if (compatResult?.canRun == false) {
        CannotRunScreen(
            gameName = gameName,
            blockers = compatResult!!.blockers,
            onOpenSettings = { viewModel.overrideCannotRun() },
            onNavigateBack = onNavigateBack
        )
        return
    }

    val categories = listOf(
        SettingsCategory.GENERAL,
        SettingsCategory.COMPATIBILITY,
        SettingsCategory.COMPONENT,
        SettingsCategory.BACKUP_RESTORE,
        SettingsCategory.CONTROLLER,
        SettingsCategory.INPUT_MAPPING,
        SettingsCategory.TOUCH_CONTROLS
    )

    val isLandscape = LocalConfiguration.current.orientation == Configuration.ORIENTATION_LANDSCAPE

    Scaffold(
        containerColor = gnBgDeepest,
        topBar = {
            TopAppBar(
                title = {
                    Text("Game Settings", style = PluviaTypography.titleMedium.copy(fontWeight = FontWeight.SemiBold), color = gnTextPrimary)
                },
                navigationIcon = {
                    IconButton(onClick = onNavigateBack) {
                        Icon(Icons.Default.ArrowBack, null, tint = gnTextPrimary)
                    }
                },
                actions = {
                    // FPS counter if game is running (matches GameHub's FPS:59.6 in top bar)
                    if (uiState.currentFps > 0) {
                        Text(
                            "FPS: ${uiState.currentFps}",
                            style = PluviaTypography.labelMedium,
                            color = gnNeonTeal,
                            modifier = Modifier.padding(end = 8.dp)
                        )
                    }
                    IconButton(onClick = { viewModel.showHelp() }) {
                        Icon(Icons.Default.HelpOutline, null, tint = gnTextSecondary)
                    }
                },
                colors = TopAppBarDefaults.topAppBarColors(containerColor = gnBgDeepest)
            )
        },
        bottomBar = {
            Box(
                modifier = Modifier
                    .fillMaxWidth()
                    .background(gnBgDeepest)
                    .padding(horizontal = 16.dp, vertical = 12.dp)
                    .navigationBarsPadding()
            ) {
                Button(
                    onClick = { onLaunch(config) },
                    enabled = compatResult?.canRun != false,
                    modifier = Modifier.fillMaxWidth().height(52.dp),
                    colors = ButtonDefaults.buttonColors(
                        containerColor = gnAccentPrimary,
                        disabledContainerColor = gnBgElevated
                    ),
                    shape = RoundedCornerShape(12.dp)
                ) {
                    Icon(Icons.Default.PlayArrow, null, modifier = Modifier.size(20.dp))
                    Spacer(Modifier.width(8.dp))
                    Text(
                        if (compatResult?.canRun == false) "Cannot Launch" else "Launch Game",
                        style = PluviaTypography.titleSmall.copy(fontWeight = FontWeight.Bold)
                    )
                }
            }
        }
    ) { padding ->

        if (isLandscape) {
            // TWO PANE — sidebar + content
            Row(
                modifier = Modifier.fillMaxSize().padding(padding)
            ) {
                // Sidebar
                Column(
                    modifier = Modifier
                        .width(200.dp)
                        .fillMaxHeight()
                        .background(gnBgSurface)
                        .verticalScroll(rememberScrollState())
                        .padding(vertical = 8.dp)
                ) {
                    categories.forEach { cat ->
                        SettingsSidebarItem(
                            category = cat,
                            isSelected = selectedCategory == cat,
                            onClick = { viewModel.selectCategory(cat) }
                        )
                    }
                }

                // Divider
                Box(modifier = Modifier.width(1.dp).fillMaxHeight().background(gnDivider))

                // Content panel
                Box(modifier = Modifier.weight(1f).fillMaxHeight()) {
                    SettingsCategoryContent(
                        category = selectedCategory,
                        config = config,
                        hardware = uiState.hardware,
                        compatResult = compatResult,
                        recommendation = recommendation,
                        showRecommendation = showRecommendation,
                        onUpdate = { viewModel.updateConfig(it) },
                        onApplyRecommendation = { viewModel.applyRecommendation() },
                        onDismissRecommendation = { viewModel.dismissRecommendation() }
                    )
                }
            }
        } else {
            // SINGLE PANE — horizontal category chips + scrollable content
            Column(modifier = Modifier.fillMaxSize().padding(padding)) {
                // Category chips
                ScrollableTabRow(
                    selectedTabIndex = categories.indexOf(selectedCategory),
                    containerColor = gnBgSurface,
                    contentColor = gnAccentPrimary,
                    edgePadding = 16.dp,
                    indicator = { tabPositions ->
                        TabRowDefaults.Indicator(
                            modifier = Modifier.tabIndicatorOffset(tabPositions[categories.indexOf(selectedCategory)]),
                            color = gnAccentPrimary,
                            height = 2.dp
                        )
                    },
                    divider = { Divider(color = gnDivider) }
                ) {
                    categories.forEachIndexed { index, cat ->
                        Tab(
                            selected = selectedCategory == cat,
                            onClick = { viewModel.selectCategory(cat) },
                            text = {
                                Text(
                                    cat.displayName,
                                    style = PluviaTypography.labelLarge,
                                    color = if (selectedCategory == cat) gnAccentPrimary else gnTextSecondary
                                )
                            }
                        )
                    }
                }

                // Content
                SettingsCategoryContent(
                    category = selectedCategory,
                    config = config,
                    hardware = uiState.hardware,
                    compatResult = compatResult,
                    recommendation = recommendation,
                    showRecommendation = showRecommendation,
                    onUpdate = { viewModel.updateConfig(it) },
                    onApplyRecommendation = { viewModel.applyRecommendation() },
                    onDismissRecommendation = { viewModel.dismissRecommendation() }
                )
            }
        }
    }
}

@Composable
fun SettingsSidebarItem(
    category: SettingsCategory,
    isSelected: Boolean,
    onClick: () -> Unit
) {
    Box(
        modifier = Modifier
            .fillMaxWidth()
            .background(if (isSelected) gnAccentSubtle else Color.Transparent)
            .clickable(onClick = onClick)
            .padding(horizontal = 16.dp, vertical = 12.dp)
    ) {
        Row(
            horizontalArrangement = Arrangement.spacedBy(10.dp),
            verticalAlignment = Alignment.CenterVertically
        ) {
            if (isSelected) {
                Box(
                    modifier = Modifier
                        .width(3.dp)
                        .height(16.dp)
                        .background(gnAccentPrimary, RoundedCornerShape(2.dp))
                )
            } else {
                Spacer(Modifier.width(3.dp))
            }
            Text(
                text = category.displayName,
                style = PluviaTypography.bodyMedium.copy(
                    fontWeight = if (isSelected) FontWeight.SemiBold else FontWeight.Normal
                ),
                color = if (isSelected) gnTextPrimary else gnTextSecondary
            )
        }
    }
}
