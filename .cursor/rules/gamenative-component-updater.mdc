## PART 6 — COMPONENTVIEWMODEL

```kotlin
@HiltViewModel
class ComponentViewModel @Inject constructor(
    private val repo: ComponentRepository
) : ViewModel() {

    private val _releasesByType = MutableStateFlow<Map<ComponentType, List<ComponentRelease>>>(emptyMap())
    val releasesByType: StateFlow<Map<ComponentType, List<ComponentRelease>>> = _releasesByType

    private val _downloadProgress = MutableStateFlow<Map<String, Float>>(emptyMap())
    val downloadProgress: StateFlow<Map<String, Float>> = _downloadProgress

    private val _availableUpdates = MutableStateFlow<List<ComponentUpdate>>(emptyList())
    val availableUpdates: StateFlow<List<ComponentUpdate>> = _availableUpdates

    fun loadAll() {
        viewModelScope.launch {
            // Load each type in parallel with 100ms stagger to avoid GitHub rate limit
            ComponentType.values().forEachIndexed { index, type ->
                launch {
                    delay(index * 100L)
                    val releases = repo.fetchLatestReleases(type)
                    _releasesByType.update { current ->
                        current.toMutableMap().also { it[type] = releases }
                    }
                }
            }

            // Check for updates after all loaded
            delay(2000)
            _availableUpdates.value = repo.checkForUpdates()
        }
    }

    fun download(release: ComponentRelease) {
        viewModelScope.launch(Dispatchers.IO) {
            repo.downloadAndInstall(release) { progress ->
                _downloadProgress.update { it.toMutableMap().also { m -> m[release.version] = progress } }
            }
            _downloadProgress.update { it.toMutableMap().also { m -> m.remove(release.version) } }
            loadAll()   // refresh list
        }
    }

    fun remove(release: ComponentRelease) {
        viewModelScope.launch(Dispatchers.IO) {
            repo.removeComponent(release)
            loadAll()
        }
    }

    fun setActive(release: ComponentRelease) {
        viewModelScope.launch {
            repo.setActiveVersion(release.component, release.version, currentAppId)
            loadAll()
        }
    }

    fun updateAll() {
        viewModelScope.launch {
            _availableUpdates.value.forEach { update ->
                download(update.latestRelease)
            }
        }
    }
}
```

