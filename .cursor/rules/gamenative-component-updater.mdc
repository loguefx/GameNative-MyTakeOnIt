## PART 3 — COMPONENT SCREEN UI (extends game-settings-screen)

This replaces the placeholder `componentItems()` lambda in
`SettingsCategoryContent` from gamenative-game-settings-screen.mdc.

```kotlin
@Composable
fun ComponentSettingsPanel(
    viewModel: ComponentViewModel = hiltViewModel()
) {
    val releasesByType by viewModel.releasesByType.collectAsState()
    val downloadProgress by viewModel.downloadProgress.collectAsState()
    val updates by viewModel.availableUpdates.collectAsState()

    LaunchedEffect(Unit) { viewModel.loadAll() }

    LazyColumn(
        modifier = Modifier.fillMaxSize(),
        contentPadding = PaddingValues(16.dp),
        verticalArrangement = Arrangement.spacedBy(16.dp)
    ) {

        // Updates available banner
        if (updates.isNotEmpty()) {
            item {
                UpdatesBanner(
                    updates = updates,
                    onUpdateAll = { viewModel.updateAll() }
                )
            }
        }

        // One section per component type
        ComponentType.values()
            .filter { it != ComponentType.PROTON_VALVE }  // dedupe Proton section
            .forEach { type ->

            val releases = releasesByType[type] ?: emptyList()
            if (releases.isEmpty()) return@forEach

            item {
                ComponentSection(
                    type          = type,
                    releases      = releases,
                    downloadProgress = downloadProgress,
                    onDownload    = { release -> viewModel.download(release) },
                    onRemove      = { release -> viewModel.remove(release) },
                    onSetActive   = { release -> viewModel.setActive(release) }
                )
            }
        }
    }
}

@Composable
fun ComponentSection(
    type: ComponentType,
    releases: List<ComponentRelease>,
    downloadProgress: Map<String, Float>,
    onDownload: (ComponentRelease) -> Unit,
    onRemove: (ComponentRelease) -> Unit,
    onSetActive: (ComponentRelease) -> Unit
) {
    Column(verticalArrangement = Arrangement.spacedBy(8.dp)) {

        // Section header
        Row(
            modifier = Modifier.fillMaxWidth(),
            horizontalArrangement = Arrangement.SpaceBetween,
            verticalAlignment = Alignment.CenterVertically
        ) {
            Text(
                text = type.displayName.uppercase(),
                style = PluviaTypography.labelSmall.copy(letterSpacing = 0.10.sp),
                color = gnTextTertiary
            )
            // Source link
            TextButton(
                onClick = { /* open github.com/${type.githubOwner}/${type.githubRepo} */ },
                contentPadding = PaddingValues(horizontal = 8.dp, vertical = 4.dp)
            ) {
                Icon(Icons.Default.OpenInBrowser, null, modifier = Modifier.size(12.dp), tint = gnTextTertiary)
                Spacer(Modifier.width(4.dp))
                Text("GitHub", style = PluviaTypography.labelSmall, color = gnTextTertiary)
            }
        }

        // Release rows
        Card(
            colors = CardDefaults.cardColors(containerColor = gnBgSurface),
            border = BorderStroke(1.dp, gnBorderCard),
            shape = RoundedCornerShape(12.dp)
        ) {
            releases.forEachIndexed { index, release ->
                ComponentReleaseRow(
                    release  = release,
                    progress = downloadProgress[release.version],
                    onDownload  = { onDownload(release) },
                    onRemove    = { onRemove(release) },
                    onSetActive = { onSetActive(release) }
                )
                if (index < releases.lastIndex) {
                    Divider(
                        color = gnDivider,
                        modifier = Modifier.padding(horizontal = 16.dp)
                    )
                }
            }
        }
    }
}

@Composable
fun ComponentReleaseRow(
    release: ComponentRelease,
    progress: Float?,               // null = not downloading, 0-1 = in progress
    onDownload: () -> Unit,
    onRemove: () -> Unit,
    onSetActive: () -> Unit
) {
    var showDetails by remember { mutableStateOf(false) }

    Column {
        Row(
            modifier = Modifier
                .fillMaxWidth()
                .clickable { showDetails = !showDetails }
                .padding(horizontal = 16.dp, vertical = 12.dp),
            horizontalArrangement = Arrangement.SpaceBetween,
            verticalAlignment = Alignment.CenterVertically
        ) {
            // Left: version name + badges
            Column(
                modifier = Modifier.weight(1f),
                verticalArrangement = Arrangement.spacedBy(4.dp)
            ) {
                Row(
                    horizontalArrangement = Arrangement.spacedBy(6.dp),
                    verticalAlignment = Alignment.CenterVertically
                ) {
                    Text(
                        text = release.version,
                        style = PluviaTypography.bodyMedium.copy(fontWeight = FontWeight.SemiBold),
                        color = gnTextPrimary
                    )
                    if (release.isRecommended) {
                        ComponentBadge("RECOMMENDED", gnNeonTeal)
                    }
                    if (release.isActive) {
                        ComponentBadge("ACTIVE", gnAccentPrimary)
                    }
                }
                Row(
                    horizontalArrangement = Arrangement.spacedBy(10.dp),
                    verticalAlignment = Alignment.CenterVertically
                ) {
                    Text(
                        text = release.releaseDate.take(10),  // YYYY-MM-DD
                        style = PluviaTypography.labelSmall,
                        color = gnTextTertiary
                    )
                    if (!release.isInstalled) {
                        Text(
                            text = "%.1f MB".format(release.sizeMb),
                            style = PluviaTypography.labelSmall,
                            color = gnTextTertiary
                        )
                    } else {
                        Text(
                            text = "Installed",
                            style = PluviaTypography.labelSmall,
                            color = gnNeonTeal
                        )
                    }
                }
            }

            // Right: action button
            when {
                progress != null -> {
                    // Downloading — show progress ring
                    Box(contentAlignment = Alignment.Center, modifier = Modifier.size(36.dp)) {
                        CircularProgressIndicator(
                            progress = { progress },
                            modifier = Modifier.size(32.dp),
                            color = gnAccentPrimary,
                            strokeWidth = 3.dp,
                            trackColor = gnBgOverlay
                        )
                        Text(
                            text = "${(progress * 100).toInt()}%",
                            style = PluviaTypography.labelSmall.copy(fontSize = 8.sp),
                            color = gnTextPrimary
                        )
                    }
                }
                !release.isInstalled -> {
                    // Not installed — download button
                    OutlinedButton(
                        onClick = onDownload,
                        border = BorderStroke(1.dp, gnAccentPrimary.copy(alpha = 0.5f)),
                        shape = RoundedCornerShape(8.dp),
                        colors = ButtonDefaults.outlinedButtonColors(contentColor = gnAccentPrimary),
                        contentPadding = PaddingValues(horizontal = 12.dp, vertical = 6.dp),
                        modifier = Modifier.height(34.dp)
                    ) {
                        Icon(Icons.Default.Download, null, modifier = Modifier.size(14.dp))
                        Spacer(Modifier.width(4.dp))
                        Text("Get", style = PluviaTypography.labelMedium)
                    }
                }
                release.isActive -> {
                    // Installed and active — checkmark, no action needed
                    Icon(
                        Icons.Default.CheckCircle,
                        contentDescription = null,
                        tint = gnNeonTeal,
                        modifier = Modifier.size(24.dp)
                    )
                }
                else -> {
                    // Installed but not active — "Use" button
                    OutlinedButton(
                        onClick = onSetActive,
                        border = BorderStroke(1.dp, gnBorderCard),
                        shape = RoundedCornerShape(8.dp),
                        colors = ButtonDefaults.outlinedButtonColors(contentColor = gnTextSecondary),
                        contentPadding = PaddingValues(horizontal = 12.dp, vertical = 6.dp),
                        modifier = Modifier.height(34.dp)
                    ) {
                        Text("Use", style = PluviaTypography.labelMedium)
                    }
                }
            }
        }

        // Download progress bar (full width, under the row)
        if (progress != null) {
            LinearProgressIndicator(
                progress = { progress },
                modifier = Modifier.fillMaxWidth().height(2.dp),
                color = gnAccentPrimary,
                trackColor = gnBgOverlay
            )
        }

        // Expanded details: release notes + remove option
        AnimatedVisibility(visible = showDetails && release.isInstalled) {
            Column(
                modifier = Modifier
                    .fillMaxWidth()
                    .background(gnBgElevated)
                    .padding(horizontal = 16.dp, vertical = 10.dp),
                verticalArrangement = Arrangement.spacedBy(8.dp)
            ) {
                if (release.releaseNotes.isNotBlank()) {
                    Text(
                        text = release.releaseNotes,
                        style = PluviaTypography.bodySmall,
                        color = gnTextSecondary
                    )
                }
                if (!release.isActive) {
                    TextButton(
                        onClick = onRemove,
                        colors = ButtonDefaults.textButtonColors(contentColor = gnStatusError)
                    ) {
                        Icon(Icons.Default.Delete, null, modifier = Modifier.size(14.dp))
                        Spacer(Modifier.width(6.dp))
                        Text("Remove ${release.version}", style = PluviaTypography.labelMedium)
                    }
                }
            }
        }
    }
}

