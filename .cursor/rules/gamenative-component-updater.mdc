## PART 2 — COMPONENT REPOSITORY

```kotlin
@Singleton
class ComponentRepository @Inject constructor(
    private val httpClient: HttpClient,
    private val componentDao: ComponentDao,   // Room DAO
    @ApplicationContext private val context: Context
) {

    // ── GitHub releases API ───────────────────────────────────────────────

    suspend fun fetchLatestReleases(type: ComponentType): List<ComponentRelease> {
        return withContext(Dispatchers.IO) {
            try {
                val url = "https://api.github.com/repos/${type.githubOwner}/${type.githubRepo}/releases?per_page=10"
                val response = httpClient.get(url) {
                    header("Accept", "application/vnd.github+json")
                    header("X-GitHub-Api-Version", "2022-11-28")
                    // Add GitHub token if available to avoid rate limiting
                    // header("Authorization", "Bearer ${BuildConfig.GITHUB_TOKEN}")
                }

                val releases = response.body<JsonArray>()
                releases.mapNotNull { releaseJson ->
                    parseRelease(type, releaseJson.jsonObject)
                }
            } catch (e: Exception) {
                Log.w("ComponentRepository", "Failed to fetch ${type.name} releases: ${e.message}")
                // Return cached versions from Room on network failure
                componentDao.getInstalledComponents(type.name).map { it.toRelease() }
            }
        }
    }

    private fun parseRelease(type: ComponentType, json: JsonObject): ComponentRelease? {
        val tagName = json["tag_name"]?.jsonPrimitive?.content ?: return null
        val assets  = json["assets"]?.jsonArray ?: return null

        // Find the ARM64 asset matching the filter
        val asset = assets.firstOrNull { assetJson ->
            val name = assetJson.jsonObject["name"]?.jsonPrimitive?.content ?: ""
            name.contains(type.assetFilter, ignoreCase = true) &&
            (name.endsWith(".tar.gz") || name.endsWith(".zip") || name.endsWith(".tar.xz"))
        }?.jsonObject ?: return null

        val fileName    = asset["name"]?.jsonPrimitive?.content ?: return null
        val downloadUrl = asset["browser_download_url"]?.jsonPrimitive?.content ?: return null
        val sizeBytes   = asset["size"]?.jsonPrimitive?.long ?: 0L
        val releaseDate = json["published_at"]?.jsonPrimitive?.content ?: ""
        val releaseBody = json["body"]?.jsonPrimitive?.content?.take(300) ?: ""

        val installPath = getInstallPath(type, tagName)

        return ComponentRelease(
            component    = type,
            version      = tagName,
            displayName  = "${type.displayName} $tagName",
            downloadUrl  = downloadUrl,
            fileName     = fileName,
            sizeMb       = sizeBytes / 1024f / 1024f,
            releaseDate  = releaseDate,
            releaseNotes = releaseBody,
            isInstalled  = File(installPath).exists(),
            isActive     = componentDao.getActiveVersion(type.name) == tagName,
            installPath  = installPath,
            isRecommended = false   // set by GameConfigRecommender after construction
        )
    }

    // ── Download & Extract ────────────────────────────────────────────────

    suspend fun downloadAndInstall(
        release: ComponentRelease,
        onProgress: (Float) -> Unit
    ): Result<String> = withContext(Dispatchers.IO) {
        try {
            val downloadDir  = File(context.cacheDir, "downloads").also { it.mkdirs() }
            val downloadFile = File(downloadDir, release.fileName)

            // Download with progress
            val response = httpClient.get(release.downloadUrl)
            val contentLength = response.contentLength() ?: 0L
            var bytesReceived = 0L

            response.bodyAsChannel().let { channel ->
                downloadFile.outputStream().use { output ->
                    val buffer = ByteArray(8192)
                    while (!channel.isClosedForRead) {
                        val read = channel.readAvailable(buffer)
                        if (read > 0) {
                            output.write(buffer, 0, read)
                            bytesReceived += read
                            if (contentLength > 0) {
                                onProgress(bytesReceived.toFloat() / contentLength.toFloat())
                            }
                        }
                    }
                }
            }

            // Extract to install path
            val installDir = File(release.installPath).also { it.mkdirs() }
            extractArchive(downloadFile, installDir)
            downloadFile.delete()

            // Record in Room
            componentDao.markInstalled(
                componentType = release.component.name,
                version       = release.version,
                installPath   = release.installPath,
                installedAt   = System.currentTimeMillis()
            )

            Result.success(release.installPath)
        } catch (e: Exception) {
            Result.failure(e)
        }
    }

    private fun extractArchive(archive: File, destDir: File) {
        when {
            archive.name.endsWith(".tar.gz") || archive.name.endsWith(".tgz") -> {
                // Use Apache Commons Compress or ProcessBuilder tar
                ProcessBuilder("tar", "xzf", archive.absolutePath, "-C", destDir.absolutePath)
                    .start().waitFor()
            }
            archive.name.endsWith(".tar.xz") -> {
                ProcessBuilder("tar", "xJf", archive.absolutePath, "-C", destDir.absolutePath)
                    .start().waitFor()
            }
            archive.name.endsWith(".zip") -> {
                java.util.zip.ZipFile(archive).use { zip ->
                    zip.entries().asSequence().forEach { entry ->
                        val outFile = File(destDir, entry.name)
                        if (entry.isDirectory) outFile.mkdirs()
                        else {
                            outFile.parentFile?.mkdirs()
                            zip.getInputStream(entry).use { input ->
                                outFile.outputStream().use { output -> input.copyTo(output) }
                            }
                        }
                    }
                }
            }
        }
    }

    // ── Remove installed component ────────────────────────────────────────

    suspend fun removeComponent(release: ComponentRelease) = withContext(Dispatchers.IO) {
        File(release.installPath).deleteRecursively()
        componentDao.markUninstalled(release.component.name, release.version)
    }

    // ── Set active version for a game ────────────────────────────────────

    suspend fun setActiveVersion(type: ComponentType, version: String, appId: Int) {
        componentDao.setActiveVersion(type.name, version, appId)
    }

    // ── Check for updates ─────────────────────────────────────────────────

    suspend fun checkForUpdates(): List<ComponentUpdate> {
        return ComponentType.values().mapNotNull { type ->
            val latest    = fetchLatestReleases(type).firstOrNull() ?: return@mapNotNull null
            val installed = componentDao.getInstalledComponents(type.name)
            val hasNewer  = installed.isNotEmpty() &&
                            installed.maxByOrNull { it.installedAt }?.version != latest.version
            if (hasNewer) ComponentUpdate(type, latest) else null
        }
    }

    // ── Install path helpers ──────────────────────────────────────────────

    private fun getInstallPath(type: ComponentType, version: String): String {
        val base = context.filesDir.absolutePath
        return when (type) {
            ComponentType.PROTON, ComponentType.PROTON_VALVE ->
                "$base/runtimes/proton/$version"
            ComponentType.DXVK, ComponentType.DXVK_ASYNC ->
                "$base/components/dxvk/$version"
            ComponentType.VKD3D ->
                "$base/components/vkd3d/$version"
            ComponentType.BOX64 ->
                "$base/components/box64/$version"
            ComponentType.TURNIP, ComponentType.MESA ->
                "$base/components/gpu_driver/$version"
            ComponentType.D8VK ->
                "$base/components/d8vk/$version"
        }
    }
}

data class ComponentUpdate(
    val type: ComponentType,
    val latestRelease: ComponentRelease
)
```

