## Part 4 — AppListAdapter

Extend `ListAdapter<AppInfo, RecyclerView.ViewHolder>(AppDiffCallback())`
NOT `RecyclerView.Adapter` directly.

### Payload constants (private)
```kotlin
private const val PAYLOAD_PROGRESS = "progress"
private const val PAYLOAD_STATUS   = "status"
private const val PAYLOAD_FAVORITE = "favorite"
```

### DiffUtil.ItemCallback
```kotlin
private class AppDiffCallback : DiffUtil.ItemCallback<AppInfo>() {
    override fun areItemsTheSame(old: AppInfo, new: AppInfo) =
        old.appId == new.appId

    override fun areContentsTheSame(old: AppInfo, new: AppInfo) =
        old == new   // data class equality

    override fun getChangePayload(old: AppInfo, new: AppInfo): Any? = when {
        old.downloadProgress != new.downloadProgress ||
        old.installState     != new.installState     -> PAYLOAD_PROGRESS
        old.isFavorite       != new.isFavorite       -> PAYLOAD_FAVORITE
        else -> null
    }
}
```

### View types
```kotlin
enum class DisplayMode { GRID, LIST }

var displayMode: DisplayMode = DisplayMode.GRID
    set(value) {
        if (field != value) {
            field = value
            notifyDataSetChanged()  // acceptable: deliberate user action, not hot path
        }
    }

override fun getItemViewType(position: Int) = when (displayMode) {
    DisplayMode.GRID -> VIEW_TYPE_GRID   // 0
    DisplayMode.LIST -> VIEW_TYPE_LIST   // 1
}
```

### onBindViewHolder with payload handling
```kotlin
override fun onBindViewHolder(
    holder: RecyclerView.ViewHolder,
    position: Int,
    payloads: MutableList<Any>
) {
    val app = getItem(position)
    if (payloads.isEmpty()) {
        // Full bind — runs on first appearance or full content change
        when (holder) {
            is GridViewHolder -> holder.bind(app)
            is ListViewHolder -> holder.bind(app)
        }
        animateCard(holder.itemView, position)
    } else {
        // Partial bind — only update the field that changed
        // This does NOT reload the cover image. Critical for download hot-path.
        payloads.forEach { payload ->
            when (payload) {
                PAYLOAD_PROGRESS -> when (holder) {
                    is GridViewHolder -> holder.updateProgress(app)
                    is ListViewHolder -> holder.updateProgress(app)
                }
                PAYLOAD_FAVORITE -> (holder as? GridViewHolder)?.updateFavorite(app)
            }
        }
    }
}
```

### Cover art loading (Coil 2.x)
```kotlin
fun bind(app: AppInfo) {
    b.tvGameTitle.text = app.name
    b.tvGameMeta.text  = buildMetaString(app)

    // Load 600x900 portrait capsule for grid cards
    b.imgGameCover.load(app.capsuleImageUrl) {
        crossfade(300)
        placeholder(R.drawable.ic_placeholder_cover)
        error(R.drawable.ic_placeholder_cover)
        // Card clips corners via cornerRadius — no transform needed here
    }

    updateStatus(app)
    updateProgress(app)
    updateFavorite(app)
}
```

For list view rows, load `app.iconImageUrl` with
`transformations(RoundedCornersTransformation(8f))` instead.

### Pop-in animation (first appearance only)
```kotlin
private val animatedPositions = HashSet<Int>()

private fun animateCard(view: View, position: Int) {
    if (animatedPositions.contains(position)) return
    animatedPositions.add(position)

    view.scaleX = 0.88f
    view.scaleY = 0.88f
    view.alpha  = 0f
    view.animate()
        .scaleX(1f).scaleY(1f).alpha(1f)
        .setDuration(220)
        .setStartDelay((position % 6 * 30).toLong())  // stagger within viewport
        .setInterpolator(DecelerateInterpolator(1.6f))
        .start()
}
```

