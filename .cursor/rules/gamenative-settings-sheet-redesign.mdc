## PART 4 — FULL REDESIGNED BOTTOM SHEET

Complete replacement for the Game Settings bottom sheet.

```kotlin
@Composable
fun GameSettingsBottomSheet(
    appId: Int,
    gameName: String,
    initialConfig: GameProfileOverrides,
    mergedVersions: List<MergedVersionEntry>,   // from ManifestRepository
    activeVersion: MergedVersionEntry?,
    onSave: (GameProfileOverrides) -> Unit,
    onDismiss: () -> Unit,
    viewModel: GameSettingsSheetViewModel = hiltViewModel()
) {
    var config by remember { mutableStateOf(initialConfig) }
    var showVersionPicker by remember { mutableStateOf(false) }
    val downloadProgress by viewModel.downloadProgress.collectAsState()

    ModalBottomSheet(
        onDismissRequest = onDismiss,
        containerColor   = gnBgDeepest,
        sheetState       = rememberModalBottomSheetState(skipPartiallyExpanded = true),
        dragHandle       = {
            Box(
                modifier = Modifier
                    .padding(top = 12.dp, bottom = 4.dp)
                    .size(width = 36.dp, height = 4.dp)
                    .background(gnTextTertiary.copy(alpha = 0.4f), RoundedCornerShape(2.dp))
            )
        }
    ) {
        Column(
            modifier = Modifier
                .fillMaxWidth()
                .navigationBarsPadding()
        ) {
            // ── Header ──────────────────────────────────────────────────
            Column(
                modifier = Modifier.padding(
                    start = 20.dp, end = 20.dp,
                    top = 8.dp, bottom = 16.dp
                ),
                verticalArrangement = Arrangement.spacedBy(2.dp)
            ) {
                Text(
                    text = "Game Settings",
                    style = PluviaTypography.headlineSmall.copy(fontWeight = FontWeight.Bold),
                    color = gnTextPrimary
                )
                Text(
                    text = gameName,
                    style = PluviaTypography.bodyMedium,
                    color = gnTextSecondary
                )
            }

            // ── Scrollable content ───────────────────────────────────────
            Column(
                modifier = Modifier
                    .weight(1f, fill = false)
                    .verticalScroll(rememberScrollState())
                    .padding(horizontal = 20.dp),
                verticalArrangement = Arrangement.spacedBy(20.dp)
            ) {

                // ── PERFORMANCE section ──────────────────────────────────
                SettingsSectionLabel("Performance")

                // Frame cap
                SettingsFieldLabel("Frame cap")
                EqualWidthChipRow {
                    SettingsChip("Off",  config.frameCap == 0,   { config = config.copy(frameCap = 0) })
                    SettingsChip("30",   config.frameCap == 30,  { config = config.copy(frameCap = 30) })
                    SettingsChip("45",   config.frameCap == 45,  { config = config.copy(frameCap = 45) })
                    SettingsChip("60",   config.frameCap == 60,  { config = config.copy(frameCap = 60) })
                    SettingsChip("90",   config.frameCap == 90,  { config = config.copy(frameCap = 90) })
                    SettingsChip("120",  config.frameCap == 120, { config = config.copy(frameCap = 120) })
                }

                // Resolution scale
                SettingsFieldLabel("Resolution scale")
                EqualWidthChipRow {
                    SettingsChip("50%",  config.resolutionScale == 0.5f,  { config = config.copy(resolutionScale = 0.5f) })
                    SettingsChip("75%",  config.resolutionScale == 0.75f, { config = config.copy(resolutionScale = 0.75f) })
                    SettingsChip("100%", config.resolutionScale == 1.0f,  { config = config.copy(resolutionScale = 1.0f) })
                    SettingsChip("125%", config.resolutionScale == 1.25f, { config = config.copy(resolutionScale = 1.25f) })
                }

                // ── GRAPHICS section ─────────────────────────────────────
                SettingsSectionLabel("Graphics")

                // Async shaders toggle
                SettingsToggleRow(
                    label   = "Async shaders",
                    checked = config.asyncShaders,
                    onToggle = { config = config.copy(asyncShaders = it) }
                )

                // DX version
                SettingsFieldLabel("DX version override")
                EqualWidthChipRow {
                    SettingsChip("Auto",  config.dxVersionOverride == DxVersion.AUTO,  { config = config.copy(dxVersionOverride = DxVersion.AUTO) })
                    SettingsChip("DX9",   config.dxVersionOverride == DxVersion.DX9,   { config = config.copy(dxVersionOverride = DxVersion.DX9) })
                    SettingsChip("DX10",  config.dxVersionOverride == DxVersion.DX10,  { config = config.copy(dxVersionOverride = DxVersion.DX10) })
                    SettingsChip("DX11",  config.dxVersionOverride == DxVersion.DX11,  { config = config.copy(dxVersionOverride = DxVersion.DX11) })
                    SettingsChip("DX12",  config.dxVersionOverride == DxVersion.DX12,  { config = config.copy(dxVersionOverride = DxVersion.DX12) })
                }

                // VSync toggle
                SettingsToggleRow(
                    label    = "VSync",
                    checked  = config.vsync,
                    onToggle = { config = config.copy(vsync = it) }
                )

                // ── RUNTIME section ──────────────────────────────────────
                SettingsSectionLabel("Runtime")

                // Wine runtime
                SettingsFieldLabel("Wine runtime")
                Row(
                    modifier = Modifier.fillMaxWidth(),
                    horizontalArrangement = Arrangement.spacedBy(8.dp)
                ) {
                    SettingsChip(
                        label    = "Stock Wine",
                        selected = config.wineRuntime == WineRuntime.STOCK,
                        onClick  = { config = config.copy(wineRuntime = WineRuntime.STOCK) },
                        modifier = Modifier.weight(1f).height(44.dp)
                    )
                    SettingsChip(
                        label    = "Wine-GE",
                        selected = config.wineRuntime == WineRuntime.WINE_GE,
                        onClick  = { config = config.copy(wineRuntime = WineRuntime.WINE_GE) },
                        modifier = Modifier.weight(1f).height(44.dp)
                    )
                }

                // Compatibility layer version picker row
                VersionPickerRow(
                    label        = "Compatibility Layer",
                    currentValue = activeVersion?.displayName ?: "Default",
                    onClick      = { showVersionPicker = true }
                )

                Spacer(Modifier.height(4.dp))
            }

            // ── Footer: Cancel + Save ────────────────────────────────────
            Divider(color = gnDivider)
            Row(
                modifier = Modifier
                    .fillMaxWidth()
                    .padding(horizontal = 20.dp, vertical = 14.dp),
                horizontalArrangement = Arrangement.spacedBy(12.dp)
            ) {
                OutlinedButton(
                    onClick = onDismiss,
                    modifier = Modifier
                        .weight(1f)
                        .height(48.dp),
                    border = BorderStroke(1.dp, gnBorderCard),
                    shape = RoundedCornerShape(12.dp),
                    colors = ButtonDefaults.outlinedButtonColors(contentColor = gnTextSecondary)
                ) {
                    Text("Cancel", style = PluviaTypography.labelLarge.copy(fontWeight = FontWeight.SemiBold))
                }
                Button(
                    onClick = { onSave(config); onDismiss() },
                    modifier = Modifier
                        .weight(2f)   // Save is wider than Cancel
                        .height(48.dp),
                    colors = ButtonDefaults.buttonColors(containerColor = gnAccentPrimary),
                    shape = RoundedCornerShape(12.dp)
                ) {
                    Text(
                        "Save",
                        style = PluviaTypography.labelLarge.copy(fontWeight = FontWeight.Bold)
                    )
                }
            }
        }
    }

    // Version picker sheet — shown over the settings sheet
    if (showVersionPicker) {
        VersionPickerSheet(
            appId            = appId,
            currentVersion   = activeVersion?.id,
            versions         = mergedVersions,
            downloadProgress = downloadProgress,
            onSelect         = { entry ->
                viewModel.setActiveVersion(appId, entry)
                showVersionPicker = false
            },
            onDownload       = { entry -> viewModel.downloadVersion(entry) },
            onDismiss        = { showVersionPicker = false }
        )
    }
}
```

