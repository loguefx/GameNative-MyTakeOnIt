## PART 1 — CHIP FIXES (highest priority visual fix)

### Problem: chips have unequal height and width

Fix all chip groups to use `equalWidth` layout so every chip in a row
is the same size. Use a custom `EqualWidthChipRow` composable:

```kotlin
@Composable
fun EqualWidthChipRow(
    modifier: Modifier = Modifier,
    content: @Composable RowScope.() -> Unit
) {
    // Use SubcomposeLayout to measure all chips and give them equal width
    Row(
        modifier = modifier.fillMaxWidth(),
        horizontalArrangement = Arrangement.spacedBy(8.dp)
    ) {
        content()
    }
}

// Each chip in the row uses Modifier.weight(1f) so they share space equally
@Composable
fun RowScope.SettingsChip(
    label: String,
    selected: Boolean,
    onClick: () -> Unit,
    enabled: Boolean = true
) {
    FilterChip(
        selected = selected,
        onClick = onClick,
        enabled = enabled,
        label = {
            Text(
                text = label,
                style = PluviaTypography.labelLarge.copy(fontWeight = FontWeight.SemiBold),
                textAlign = TextAlign.Center,
                maxLines = 1,           // NEVER allow vertical text wrapping
                overflow = TextOverflow.Ellipsis,
                modifier = Modifier.fillMaxWidth()
            )
        },
        modifier = Modifier
            .weight(1f)             // equal width for all chips in the row
            .height(44.dp),         // fixed height — no chip is ever taller
        shape = RoundedCornerShape(22.dp),
        colors = FilterChipDefaults.filterChipColors(
            selectedContainerColor = gnAccentPrimary,
            selectedLabelColor     = Color.White,
            containerColor         = gnBgElevated,
            labelColor             = gnTextSecondary,
            disabledContainerColor = gnBgSurface,
            disabledLabelColor     = gnTextTertiary
        ),
        border = FilterChipDefaults.filterChipBorder(
            enabled         = enabled,
            selected        = selected,
            borderColor     = gnBorderCard,
            selectedBorderColor = Color.Transparent,
            borderWidth     = 1.dp
        )
    )
}
```

