## PART 2 — Game Configuration Engine

### GameConfig.kt — the full configuration for one game on one device

```kotlin
data class GameConfig(
    // Identity
    val appId: Int,
    val configVersion: Int = 1,

    // Proton / Wine runtime
    val protonVersion: ProtonVersion,   // see enum below
    val wineRuntime: WineRuntime,

    // Graphics API
    val dxVersion: DxVersion,           // AUTO, DX9, DX10, DX11, DX12
    val dxvkEnabled: Boolean,
    val vkd3dEnabled: Boolean,
    val d8vkEnabled: Boolean,

    // Resolution and display
    val resolutionScale: Float,         // 0.5 – 1.0 – 1.25
    val fpsLimit: Int,                  // 0=uncapped, 30, 45, 60, 90, 120
    val vsync: Boolean,

    // DXVK specific
    val dxvkAsync: Boolean,
    val dxvkNumCompilerThreads: Int,
    val dxvkDeviceLocalMemoryMiB: Int,  // calculated from hardware RAM
    val dxvkPresentMode: String,        // "MAILBOX", "FIFO", "FIFO_RELAXED"

    // VKD3D specific
    val vkd3dWorkerThreads: Int,
    val vkd3dShaderModel: String,       // "6_5", "6_4", "6_3"

    // Wine
    val esyncEnabled: Boolean,
    val fsyncEnabled: Boolean,
    val wineDebug: Boolean,             // always false in release

    // Box64
    val box64BigBlock: Boolean,
    val box64StrongMem: Boolean,
    val box64DynarecFastRound: Boolean,

    // CPU
    val cpuAffinityMask: String,        // from hardware profile P-core mask

    // Extra launch args (for known game-specific fixes)
    val extraEnvVars: Map<String, String>,
    val wineLaunchArgs: String,

    // Metadata
    val preset: ConfigPreset,           // RECOMMENDED, PERFORMANCE, QUALITY, COMPATIBILITY
    val notes: String                   // shown to user explaining why these settings
)

enum class ProtonVersion {
    PROTON_10_0,
    PROTON_9_0,
    PROTON_8_0,
    PROTON_7_0,
    WINE_GE_LATEST,
    STOCK_WINE
}

enum class ConfigPreset { RECOMMENDED, PERFORMANCE, QUALITY, COMPATIBILITY, CUSTOM }
```

