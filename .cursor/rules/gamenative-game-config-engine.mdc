## PART 1 — Hardware Detection

### HardwareProfile.kt

Create this class. It must run ONCE on first app launch and cache the
result. Re-read on app update.

```kotlin
data class HardwareProfile(
    // CPU
    val cpuSoC: String,               // "Snapdragon 8 Gen 3", "Dimensity 9300", etc.
    val cpuCores: Int,                // total core count
    val cpuPCoreCount: Int,           // performance core count
    val cpuECoreCount: Int,           // efficiency core count
    val cpuPCoreMask: String,         // hex mask e.g. "0xF0" for pinning
    val cpuMaxFreqMhz: Int,           // highest P-core max clock

    // GPU
    val gpuVendor: GpuVendor,         // ADRENO, MALI, POWERVR, UNKNOWN
    val gpuModel: String,             // "Adreno 750", "Mali-G715", etc.
    val gpuOpenGLES: String,          // "3.2"
    val gpuVulkanVersion: String,     // "1.3.255"
    val gpuDriverVersion: String,     // raw GL_VERSION string
    val supportsVulkan13: Boolean,
    val supportsMeshShaders: Boolean,
    val supportsRayTracing: Boolean,  // almost always false on mobile

    // Memory
    val totalRamMb: Int,
    val availableRamMb: Int,
    val storageType: StorageType,     // UFS_3_1, UFS_3_0, UFS_2_2, EMMC

    // Display
    val displayRefreshHz: Int,        // 60, 90, 120, 144, 165
    val displayWidthPx: Int,
    val displayHeightPx: Int,

    // Thermal
    val thermalHeadroom: Float,       // 0.0-1.0, from PowerManager.getThermalHeadroom
    val sustainedPerformanceSupported: Boolean
)

enum class GpuVendor { ADRENO, MALI, POWERVR, UNKNOWN }
enum class StorageType { UFS_3_1, UFS_3_0, UFS_2_2, EMMC, UNKNOWN }
```

### HardwareDetector.kt

```kotlin
object HardwareDetector {

    fun detect(context: Context): HardwareProfile {
        val activityManager = context.getSystemService(ActivityManager::class.java)
        val powerManager = context.getSystemService(PowerManager::class.java)
        val windowManager = context.getSystemService(WindowManager::class.java)

        // GPU detection via OpenGL
        val egl = EGLContext.getEGL() as EGL10
        // ... initialize EGL context to read GL_RENDERER and GL_VERSION
        val glRenderer = readGlRenderer()   // e.g. "Adreno (TM) 750"
        val glVersion  = readGlVersion()

        val gpuVendor = when {
            glRenderer.contains("Adreno", ignoreCase = true)  -> GpuVendor.ADRENO
            glRenderer.contains("Mali",   ignoreCase = true)  -> GpuVendor.MALI
            glRenderer.contains("PowerVR",ignoreCase = true)  -> GpuVendor.POWERVR
            else -> GpuVendor.UNKNOWN
        }

        // CPU detection from /proc/cpuinfo and sysfs
        val cpuInfo    = File("/proc/cpuinfo").readText()
        val socName    = readSoCName()    // from /sys/devices/soc0/soc_id or build props
        val coreFreqs  = readCoreMaxFreqs()
        val pCoreMask  = detectPCoreMask(coreFreqs)

        // RAM from ActivityManager
        val memInfo = ActivityManager.MemoryInfo()
        activityManager.getMemoryInfo(memInfo)
        val totalRamMb = (memInfo.totalMem / 1024 / 1024).toInt()

        // Display
        val displayMode = windowManager.defaultDisplay.mode
        val refreshHz   = displayMode.refreshRate.toInt()

        // Vulkan version
        val vulkanVersion = readVulkanVersion()  // from Vulkan instance properties

        return HardwareProfile(
            cpuSoC       = socName,
            cpuCores     = Runtime.getRuntime().availableProcessors(),
            cpuPCoreCount = coreFreqs.count { it > 2000 },  // >2GHz = P-core
            cpuECoreCount = coreFreqs.count { it <= 2000 },
            cpuPCoreMask  = pCoreMask,
            cpuMaxFreqMhz = coreFreqs.maxOrNull() ?: 0,
            gpuVendor    = gpuVendor,
            gpuModel     = glRenderer,
            gpuOpenGLES  = glVersion,
            gpuVulkanVersion  = vulkanVersion,
            gpuDriverVersion  = glVersion,
            supportsVulkan13  = vulkanVersion.startsWith("1.3"),
            supportsMeshShaders = false,   // check VK extension list
            supportsRayTracing  = false,   // almost never true on mobile
            totalRamMb   = totalRamMb,
            availableRamMb = (memInfo.availMem / 1024 / 1024).toInt(),
            storageType  = detectStorageType(),
            displayRefreshHz = refreshHz,
            displayWidthPx   = displayMode.physicalWidth,
            displayHeightPx  = displayMode.physicalHeight,
            thermalHeadroom  = powerManager.getThermalHeadroom(5),
            sustainedPerformanceSupported = powerManager.isSustainedPerformanceModeSupported
        )
    }

    private fun detectPCoreMask(coreFreqs: List<Int>): String {
        // Build bitmask of cores with max freq > 2000MHz (P-cores)
        var mask = 0
        coreFreqs.forEachIndexed { index, freq ->
            if (freq > 2000) mask = mask or (1 shl index)
        }
        return "0x${mask.toString(16).uppercase()}"
    }

    private fun readCoreMaxFreqs(): List<Int> {
        return (0..7).mapNotNull { core ->
            try {
                File("/sys/devices/system/cpu/cpu$core/cpufreq/cpuinfo_max_freq")
                    .readText().trim().toIntOrNull()?.div(1000)  // kHz → MHz
            } catch (e: Exception) { null }
        }
    }
}
```

