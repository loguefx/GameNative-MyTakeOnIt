            // Wine section
            item { ConfigSectionHeader("WINE") }
            item {
                ConfigCard {
                    ConfigToggleRow(
                        label = "ESYNC",
                        description = "Eventfd sync — greatly reduces CPU usage in multithreaded games",
                        checked = config.esyncEnabled,
