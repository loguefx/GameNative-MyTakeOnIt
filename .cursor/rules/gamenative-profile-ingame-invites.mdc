### Accepting an invite — passing connect string to Wine

```kotlin
fun acceptInvite(invite: GameInvite) {
    viewModelScope.launch(Dispatchers.IO) {
        if (isGameCurrentlyRunning()) {
            // Game is already running — pass the connect string directly
            // Use ContainerUtils to run a command inside the container
            ContainerUtils.runCommand(
                context = appContext,
                command = "wine start /unix steam://run/${invite.gameAppId}//${invite.connectString}/"
            )
        } else {
            // Game is not running — launch the game with the connect string as a launch arg
            // Store the connect string so LaunchOrchestrator picks it up
            pendingConnectString = invite.connectString
            pendingConnectAppId = invite.gameAppId
            // Navigate to the game's page so user can see it launching
            withContext(Dispatchers.Main) {
                navController.navigate("gameDetail/${invite.gameAppId}?autoLaunch=true")
            }
        }
    }
}
```

