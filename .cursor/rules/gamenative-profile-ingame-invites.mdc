## PART 2 — IN-GAME CHAT SIDE PANEL

### What this is

When a game is running (XServerScreen is active) and a Steam chat message
arrives, the user can open a slide-in panel from the right edge of the screen
to read and reply without leaving the game. The game continues running behind
the panel at full speed — no pause, no suspend.

### How to trigger it

Two entry points:
1. A new message arrives while in-game → show a small toast-style notification
   at the top of the screen for 4 seconds with the sender's name + message preview.
   Tapping the toast slides the panel open.
2. A persistent edge handle on the right side of the screen (small 48dp × 4dp
   pill, gnAccentPrimary color, 50% alpha when idle). Tapping it toggles the panel.

### Panel layout

```kotlin
// The panel slides in from the right over the game.
// It does NOT replace the game view — it overlays it.
// Width = 320.dp (fixed), height = fillMaxHeight
// Use AnimatedVisibility with slideInHorizontally + slideOutHorizontally

// In XServerScreen.kt, add this at the root Box level AFTER the game surface:
Box(modifier = Modifier.fillMaxSize()) {

    // Game surface (existing XServer content here — untouched)
    XServerSurfaceView(modifier = Modifier.fillMaxSize())

    // Edge handle (always visible, low opacity when panel closed)
    Box(
        modifier = Modifier
            .align(Alignment.CenterEnd)
            .width(4.dp)
            .height(48.dp)
            .offset(x = if (panelOpen) 0.dp else 4.dp)
            .background(gnAccentPrimary.copy(alpha = if (panelOpen) 0f else 0.5f), RoundedCornerShape(2.dp))
            .clickable { panelOpen = !panelOpen }
    )

    // Incoming message toast
    AnimatedVisibility(
        visible = showToast,
        modifier = Modifier.align(Alignment.TopCenter).padding(top = 48.dp),
        enter = slideInVertically() + fadeIn(),
        exit = slideOutVertically() + fadeOut()
    ) {
        IncomingMessageToast(
            senderName = toastSenderName,
            messagePreview = toastMessagePreview,
            avatarUrl = toastAvatarUrl,
            onClick = { panelOpen = true; showToast = false }
        )
    }

    // Side chat panel
    AnimatedVisibility(
        visible = panelOpen,
        modifier = Modifier.align(Alignment.CenterEnd),
        enter = slideInHorizontally(initialOffsetX = { it }),
        exit = slideOutHorizontally(targetOffsetX = { it })
    ) {
        InGameChatPanel(
            steamId = activeChatSteamId,
            onClose = { panelOpen = false },
            onSendMessage = { msg -> chatViewModel.sendMessage(activeChatSteamId, msg) },
            messages = chatViewModel.messages.collectAsState().value
        )
    }
}
```

### InGameChatPanel composable

```kotlin
@Composable
fun InGameChatPanel(
    steamId: String,
    onClose: () -> Unit,
    onSendMessage: (String) -> Unit,
    messages: List<ChatMessage>
) {
    // Semi-transparent background so the game is faintly visible behind
    Surface(
        modifier = Modifier
            .width(320.dp)
            .fillMaxHeight(),
        color = gnBgDeepest.copy(alpha = 0.95f),
        tonalElevation = 0.dp
    ) {
        Column(modifier = Modifier.fillMaxSize()) {

            // Panel header
            Row(
                modifier = Modifier
                    .fillMaxWidth()
                    .background(gnBgSurface)
                    .padding(horizontal = 16.dp, vertical = 12.dp),
                verticalAlignment = Alignment.CenterVertically,
                horizontalArrangement = Arrangement.SpaceBetween
            ) {
                Row(
                    verticalAlignment = Alignment.CenterVertically,
                    horizontalArrangement = Arrangement.spacedBy(10.dp)
                ) {
                    AsyncImage(
                        model = friendAvatarUrl,
                        modifier = Modifier.size(32.dp).clip(CircleShape)
                    )
                    Column {
                        Text(
                            text = friendName,
                            style = PluviaTypography.titleSmall.copy(fontWeight = FontWeight.SemiBold),
                            color = gnTextPrimary
                        )
                        Text(
                            text = friendPresence,  // "Online" / "In Game: Elden Ring"
                            style = PluviaTypography.bodySmall,
                            color = gnTextSecondary
                        )
                    }
                }
                // Close button — returns focus to game
                IconButton(onClick = onClose) {
                    Icon(
                        Icons.Filled.KeyboardArrowRight,
                        contentDescription = "Close chat",
                        tint = gnTextSecondary
                    )
                }
            }

            Divider(color = gnDivider)

            // Messages list
            LazyColumn(
                modifier = Modifier.weight(1f).padding(horizontal = 12.dp),
                reverseLayout = true,   // newest at bottom
                verticalArrangement = Arrangement.spacedBy(6.dp),
                contentPadding = PaddingValues(vertical = 8.dp)
            ) {
                items(messages.reversed(), key = { it.id }) { msg ->
                    ChatBubble(message = msg)
                }
            }

            Divider(color = gnDivider)

            // Input row
            Row(
                modifier = Modifier
                    .fillMaxWidth()
                    .background(gnBgSurface)
                    .padding(horizontal = 12.dp, vertical = 10.dp)
                    .navigationBarsPadding()
                    .imePadding(),   // CRITICAL: rises above keyboard
                verticalAlignment = Alignment.CenterVertically,
                horizontalArrangement = Arrangement.spacedBy(8.dp)
            ) {
                var inputText by remember { mutableStateOf("") }

                TextField(
                    value = inputText,
                    onValueChange = { inputText = it },
                    modifier = Modifier.weight(1f),
                    placeholder = {
                        Text("Message…", color = gnTextTertiary, style = PluviaTypography.bodyMedium)
                    },
                    colors = TextFieldDefaults.colors(
                        focusedContainerColor = gnBgElevated,
                        unfocusedContainerColor = gnBgElevated,
                        focusedIndicatorColor = Color.Transparent,
                        unfocusedIndicatorColor = Color.Transparent,
                        focusedTextColor = gnTextPrimary,
                        unfocusedTextColor = gnTextPrimary,
                        cursorColor = gnAccentPrimary
                    ),
                    shape = RoundedCornerShape(10.dp),
                    singleLine = false,
                    maxLines = 3,
                    keyboardOptions = KeyboardOptions(imeAction = ImeAction.Send),
                    keyboardActions = KeyboardActions(
                        onSend = {
                            if (inputText.isNotBlank()) {
                                onSendMessage(inputText.trim())
                                inputText = ""
                            }
                        }
                    )
                )

                // Send button
                IconButton(
                    onClick = {
                        if (inputText.isNotBlank()) {
                            onSendMessage(inputText.trim())
                            inputText = ""
                        }
                    },
                    modifier = Modifier
                        .size(42.dp)
                        .background(gnAccentPrimary, RoundedCornerShape(10.dp))
                ) {
                    Icon(Icons.Filled.Send, contentDescription = "Send", tint = Color.White)
                }
            }
        }
    }
}
